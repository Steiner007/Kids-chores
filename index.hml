,"rarity":"rare","power":6,"anim":"af"},{"id":"monstertruk","name":"Crusher McFace","type":"cube","rarity":"rare","power":7,"anim":"ap"},{"id":"taxicab","name":"Honky McBeep","type":"thunder","rarity":"common","power":4,"anim":"wo"},{"id":"clunker","name":"Rusty McRust","type":"blob","rarity":"common","power":2,"anim":"wo"},{"id":"sportscar","name":"Slick Silvio","type":"wind","rarity":"epic","power":8,"anim":"af"},{"id":"pirateboat","name":"The Stinky Kraken","type":"water","rarity":"rare","power":7,"anim":"ab"},{"id":"tugboat","name":"Tug McGruff","type":"water","rarity":"common","power":4,"anim":"wo"},{"id":"sailboat","name":"Windy Wanda","type":"wind","rarity":"common","power":5,"anim":"ap"},{"id":"submarine","name":"Depth Charge Dave","type":"water","rarity":"rare","power":6,"anim":"ab"},{"id":"canoe","name":"Paddle Panic Pete","type":"water","rarity":"common","power":3,"anim":"wo"},{"id":"pizzaslice","name":"Cheesy Revenge","type":"fire","rarity":"common","power":4,"anim":"af"},{"id":"pizzaboss","name":"The Big Pepperoni","type":"fire","rarity":"epic","power":8,"anim":"ap"},{"id":"calzone","name":"Foldini the Sealed","type":"fire","rarity":"common","power":5,"anim":"wo"},{"id":"hotdog","name":"Wiener the Weird","type":"fire","rarity":"common","power":3,"anim":"wo"},{"id":"donut","name":"Glazy McSprinkles","type":"blob","rarity":"common","power":3,"anim":"wo"},{"id":"tacobell","name":"El Taco Loco","type":"fire","rarity":"common","power":5,"anim":"af"},{"id":"bigeye","name":"The Googler","type":"shadow","rarity":"common","power":5,"anim":"ap"},{"id":"brainiac","name":"Big Brain Barry","type":"thunder","rarity":"rare","power":7,"anim":"ap"},{"id":"bigfoot2","name":"Stompy McStompface","type":"blob","rarity":"common","power":4,"anim":"wo"},{"id":"bonehead","name":"Boney Bob","type":"shadow","rarity":"rare","power":6,"anim":"ap"},{"id":"handsy","name":"The Grabber","type":"wind","rarity":"common","power":5,"anim":"af"},{"id":"nosejob","name":"Sniffy McSniff","type":"water","rarity":"common","power":2,"anim":"wo"},{"id":"teethter","name":"Chomp Chomp","type":"knight","rarity":"rare","power":6,"anim":"ab"}];

const KIDS=[{name:"Kid 1",e:"K1"},{name:"Kid 2",e:"K2"},{name:"Kid 3",e:"K3"}];
const CHORES=[
  {n:"Make bed",s:"s",p:5},{n:"Brush teeth",s:"s",p:5},{n:"Clear dishes",s:"s",p:10},{n:"Feed pet",s:"s",p:10},{n:"Pick up toys",s:"s",p:10},
  {n:"Clean room",s:"m",p:15},{n:"Fold laundry",s:"m",p:20},{n:"Help sibling",s:"m",p:20},{n:"Vacuum",s:"m",p:25},{n:"Set table",s:"m",p:25},{n:"Take out trash",s:"m",p:30},
  {n:"Wash dishes",s:"b",p:35},{n:"Clean bathroom",s:"b",p:40},{n:"Mow lawn",s:"b",p:45},{n:"Initiative!",s:"b",p:50}
];
const PACKS=[
  {n:"Common Pack",i:"📦",c:50,o:"80% Common · 18% Rare · 2% Epic",w:[0.8,0.18,0.02,0,0]},
  {n:"Rare Pack",i:"💙",c:120,o:"50% Common · 40% Rare · 10% Epic",w:[0.5,0.4,0.1,0,0]},
  {n:"Epic Pack",i:"💜",c:250,o:"30% Rare · 60% Epic · 10% Legendary",w:[0,0.3,0.6,0.1,0]},
  {n:"Legendary Pack",i:"⭐",c:500,o:"50% Epic · 40% Legendary · 10% Ultra",w:[0,0,0.5,0.4,0.1]}
];
const BADS=[
  {n:"Talking back",s:"s",p:5},{n:"Left a mess",s:"s",p:5},{n:"Forgot chore",s:"s",p:10},{n:"Screen time overrun",s:"s",p:10},{n:"Not listening",s:"s",p:10},
  {n:"Mean to sibling",s:"m",p:15},{n:"Threw a tantrum",s:"m",p:20},{n:"Lied",s:"m",p:20},{n:"Ignored rules",s:"m",p:25},{n:"Snuck screen time",s:"m",p:25},
  {n:"Broke something",s:"b",p:35},{n:"Big attitude",s:"b",p:40},{n:"Serious rule break",s:"b",p:50}
];

const QUESTS=[
  {n:"Make bed 3 days",d:"3 days in a row",r:25,t:"pts"},
  {n:"Help a sibling",d:"Without being asked",r:15,t:"pts"},
  {n:"No reminders week",d:"All chores without reminders",r:50,t:"pts"},
  {n:"5 chores this week",d:"Complete any 5 chores",r:"pack",t:"pack"},
  {n:"Streak bonus",d:"1 chore daily for 5 days",r:30,t:"pts"}
];
const EVENTS=[
  {n:"🌟 Double Points Day",d:"All chores worth 2x!"},
  {n:"🍀 Lucky Pack Day",d:"Better pack odds!"},
  {n:"😂 Silly Mode",d:"Monsters dance extra silly!"}
];
const RP={common:[],rare:[],epic:[],legendary:[],ultra:[]};
SILLY_MONSTERS.forEach(m=>{
  RP[m.rarity]&&RP[m.rarity].push(m);
  if(m.power>=10)RP.ultra.push(m);
});
const S={kids:KIDS.map(k=>({...k,pts:0,earned:0,col:[],streak:0,lastChoreDate:'',nicks:{}})),sk:0,shk:0,ck:0,qk:0,log:[],ev:null,qd:{},rq:[],ri:0,rp:'',battleHistory:[],dungeonLevel:0};
// ── Runtime state vars - declared early so DOMContentLoaded can use them ──
var mode='1v1', selL=[], selR=[], fighting=false;
var mxL=0, mxR=0, cL=0, cR=0;
var pc=null, pctx=null, particles=[];
var monHP={};
var battleKidL=0, battleKidR=1;
var fusionSel=[];
var dqState=null;
var tTO;
var _ac=null;
var upsetOccurred=false;

function lvl(t){return Math.min(10,Math.floor(t/200)+1)}
function xpw(t){return Math.min(100,(t%200)/2)}
function rKids(){
  document.getElementById("kg").innerHTML=S.kids.map((k,i)=>`
    <div class="kid-card k${i} ${S.sk===i?'kid-selected':''}" onclick="setCK(${i})" style="cursor:pointer">
      <div class="kid-avatar">${k.e}<\/div>
      <div class="kid-name">${k.name}${k.collectionComplete?' 👑':''} <span onclick="event.stopPropagation();editName(${i})" style="cursor:pointer;font-size:12px;opacity:0.7" title="Rename">✏️<\/span><\/div>
      <div class="kid-level">Lv${lvl(k.earned)} Trainer${k.streak>1?' · 🔥'+k.streak:''}<\/div>
      <div class="kid-points">${k.pts}<\/div>
      <div class="kid-pts-label">pts · 🃏${k.col.length}<\/div>
      <div class="xbar-w"><div class="xbar" style="width:${xpw(k.earned)}%"><\/div><\/div>
      ${S.sk===i?'<div style="font-size:8px;font-weight:900;color:#FFD600;margin-top:3px;letter-spacing:1px;opacity:0.9">▼ AWARDING<\/div>':''}
    <\/div>`).join("");
}
function editName(i){
  const k=S.kids[i];
  const existing=document.getElementById('nameModal');
  if(existing)existing.remove();
  const m=document.createElement('div');
  m.id='nameModal';
  m.style.cssText='position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);display:flex;align-items:center;justify-content:center';
  m.innerHTML=`<div style="background:#1a1008;border:2px solid #FFD600;border-radius:14px;padding:24px;min-width:260px;text-align:center;box-shadow:0 0 40px rgba(255,214,0,0.3)">
    <div style="font-size:14px;font-weight:900;color:#FFD600;margin-bottom:14px;text-transform:uppercase;letter-spacing:2px">✏️ Rename Kid</div>
    <input id="nameInput" data-idx="${i}" value="${k.name}" style="width:100%;padding:10px;border-radius:8px;border:2px solid #FFD600;background:#120a04;color:#FFD600;font-size:16px;font-weight:700;text-align:center;outline:none;box-sizing:border-box" maxlength="20">
    <div style="display:flex;gap:8px;margin-top:14px">
      <button onclick="document.getElementById(\'nameModal\').remove()" style="flex:1;padding:10px;border-radius:8px;border:1px solid rgba(255,214,0,0.3);background:transparent;color:#c4982a;font-weight:700;cursor:pointer;font-size:13px">Cancel</button>
      <button onclick="saveName()" style="flex:1;padding:10px;border-radius:8px;border:none;background:linear-gradient(135deg,#FFD600,#FF8C00);color:#120a04;font-weight:900;cursor:pointer;font-size:13px">Save ✓</button>
    </div>
  </div>`;
  document.body.appendChild(m);
  const inp=document.getElementById('nameInput');
  setTimeout(()=>{inp.focus();inp.select();},50);
  m.addEventListener('click',e=>{if(e.target===m)m.remove();});
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')saveName();});
}

function saveName(){
  const inp=document.getElementById('nameInput');
  if(!inp)return;
  const val=inp.value.trim();
  if(!val)return;
  const i=parseInt(inp.dataset.idx);
  const k=S.kids[i];
  k.name=val;
  k.e=val[0].toUpperCase();
  document.getElementById('nameModal').remove();
  rKids();rChores();
}
function pills(id,sk,cb){document.getElementById(id).innerHTML=S.kids.map((k,i)=>`<div class="kpill ${S[sk]===i?"ak"+i:""}" onclick="${cb}(${i})">${k.name}<\/div>`).join("")}
function rChores(){
  const sl={s:"Small",m:"Medium",b:"Big"},sc={s:"szs",m:"szm",b:"szb"};
  document.getElementById("cgrid").innerHTML=CHORES.map((c,i)=>`<div class="chore-btn" onclick="award(${i})"><span class="cbsz ${sc[c.s]}">Good ${sl[c.s]}<\/span><div class="cbname">${c.n}<\/div><div class="cbpts">+${c.p}<\/div><\/div>`).join("");
  document.getElementById("bgrid").innerHTML=BADS.map((b,i)=>`<div class="chore-btn bad-btn" onclick="deduct(${i})"><span class="cbsz szb-${b.s}">Bad ${sl[b.s]}<\/span><div class="cbname">${b.n}<\/div><div class="cbpts bad-pts">-${b.p}<\/div><\/div>`).join("");
}
function setCK(i){
  S.sk=i; S.shk=i; S.ck=i; S.qk=i;
  rKids(); rChores();
  // Also refresh whichever tab is active
  const activePanel=document.querySelector('.panel.active');
  if(activePanel){
    const id=activePanel.id;
    if(id==='panel-shop')rShop();
    if(id==='panel-collection')rCol();
    if(id==='panel-quests')rQuests();
  }
}
function award(idx){
  const k=S.kids[S.sk],c=CHORES[idx];
  let p=c.p;if(S.ev===0)p*=2;
  const prevLvl=lvl(k.earned);
  k.pts+=p;k.earned+=p;
  // Streak tracking
  const today=new Date().toDateString();
  if(k.lastChoreDate===today){
    // already did chores today, no streak change
  } else if(k.lastChoreDate===new Date(Date.now()-86400000).toDateString()){
    k.streak=(k.streak||0)+1;
    sfx('streak');
    if(k.streak>1)toast('🔥 '+k.name+' is on a '+k.streak+' day streak!');
  } else {
    k.streak=1;
  }
  k.lastChoreDate=today;
  S.log.unshift({k:k.name,c:c.n,p,t:new Date().toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"})});
  sfx('award');
  rKids();rLog();toast("🌟 "+k.name+" +"+p+" pts!");saveGame();
  // Level-up check
  if(lvl(k.earned)>prevLvl) setTimeout(()=>doLevelUp(S.kids.indexOf(k)),300);
}
function deduct(idx){
  const k=S.kids[S.sk],b=BADS[idx];
  const penalty=b.p;
  k.pts=Math.max(0,k.pts-penalty);
  // Break streak on bad behavior
  if(k.streak>0){ k.streak=0; }
  S.log.unshift({k:k.name,c:b.n,p:-penalty,t:new Date().toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"})});
  sfx('miss');
  rKids();rLog();toast("⚠️ "+k.name+" -"+penalty+" pts");saveGame();
}

function doLevelUp(kidIdx){
  const k=S.kids[kidIdx];
  const lv=lvl(k.earned);
  sfx('levelup');
  // Free pack on level up
  const freePack=PACKS[lv>=8?3:lv>=5?2:lv>=3?1:0];
  const ownedIds2=new Set(k.col.map(m=>m.id));const pulled=[rollUnique(freePack,ownedIds2),rollUnique(freePack,ownedIds2),rollUnique(freePack,ownedIds2)];
  pulled.forEach(m=>k.col.push(m));
  showLevelUp(kidIdx,lv,pulled);
  checkCollectionComplete(kidIdx);
}
function rLog(){
  const el=document.getElementById("alog");
  if(!el)return;
  if(!S.log.length){el.innerHTML="<div class=\"es\">No activity yet! 🌟<\/div>";return}
  el.innerHTML=S.log.slice(0,15).map(e=>`<div class="log-item"><span>${e.k} · ${e.c}<\/span><span style="display:flex;gap:7px"><span class="${e.p<0?'lp-neg':'lp'}">${e.p>0?'+'+e.p:e.p}<\/span><span style="color:#ccc">${e.t}<\/span><\/span><\/div>`).join("");
}
function rShop(){
  const k=S.kids[S.shk];
  const pts=k.pts;
  document.getElementById("shpts").textContent="💰 "+k.name+": "+pts+" pts";
  document.getElementById("pgrid").innerHTML=PACKS.map((p,i)=>`<div class="pack-card ${pts<p.c?"pack-locked":""}" onclick="buy(${i})"><span class="pack-icon">${p.i}<\/span><div class="pack-name">${p.n}<\/div><div class="pack-cost">${p.c} pts<\/div><div class="pack-odds">${p.o}<\/div><\/div>`).join("");
}
function setSK(i){S.sk=i;S.shk=i;S.ck=i;S.qk=i;rKids();rShop();}
function wR(w){let r=Math.random(),c=0;for(let i=0;i<w.length;i++){c+=w[i];if(r<c)return i}return w.length-1}
function roll(pack){
  const rs=["common","rare","epic","legendary","ultra"];
  const rk=rs[wR(pack.w)];
  const pool=RP[rk]&&RP[rk].length?RP[rk]:RP.common;
  const base=pool[Math.floor(Math.random()*pool.length)];
  return{...base,uid:Date.now()+Math.random()};
}
function rollUnique(pack,ownedIds){
  const rs=["common","rare","epic","legendary","ultra"];
  const rk=rs[wR(pack.w)];
  const fullPool=RP[rk]&&RP[rk].length?RP[rk]:RP.common;
  // Try to find something not yet owned
  const unowned=fullPool.filter(m=>!ownedIds.has(m.id));
  const pool=unowned.length?unowned:fullPool; // fall back if kid has them all
  const base=pool[Math.floor(Math.random()*pool.length)];
  return{...base,uid:Date.now()+Math.random()};
}
function buy(pi){
  const pack=PACKS[pi],kid=S.kids[S.shk];
  if(kid.pts<pack.c)return;
  kid.pts-=pack.c;
  const ownedIds=new Set(kid.col.map(m=>m.id));
  const pulled=[rollUnique(pack,ownedIds),rollUnique(pack,ownedIds),rollUnique(pack,ownedIds)];
  pulled.forEach(m=>{kid.col.push(m);ownedIds.add(m.id);});
  S.rq=pulled;S.ri=0;S.rp=pack.i+" "+pack.n;
  sfx('buy');
  const kidIdx2=S.kids.indexOf(kid);
  checkCollectionComplete(kidIdx2);
  rKids();rShop();rReveal();saveGame();
}
function rReveal(){
  const m=S.rq[S.ri],total=S.rq.length;
  if(!m){
    const area=document.getElementById('pra');
    if(area)area.innerHTML='';
    return;
  }
  const area=document.getElementById('pra');
  if(!area)return;

  // Step 1: show box
  area.innerHTML='<div class="pack-open-overlay" id="packOpenOverlay" onclick="if(event.target===this)cRev()">'
    +'<div style="font-size:13px;font-weight:900;color:#FFD600;margin-bottom:20px;letter-spacing:2px;text-transform:uppercase">'+S.rp+' — Card '+(S.ri+1)+' of '+total+'</div>'
    +'<div class="pack-box-wrap" id="packBoxWrap">'
      +'<div class="pack-box-lid" id="packBoxLid">⭐</div>'
      +'<div class="pack-box-body"></div>'
      +'<div class="pack-box-star" id="packBoxStar">'+getRarityEmoji(m.rarity)+'</div>'
    +'</div>'
    +'<div id="packRevealCard" style="opacity:0"></div>'
    +'</div>';

  sfx('buy');

  // Step 2: open lid after 600ms
  setTimeout(()=>{
    const lid=document.getElementById('packBoxLid');
    if(lid)lid.classList.add('open');
    spawnPackSparkles();
  },600);

  // Step 3: show card after 1.1s
  setTimeout(()=>{
    const star=document.getElementById('packBoxStar');
    if(star)star.classList.add('show');
    const cardEl=document.getElementById('packRevealCard');
    if(!cardEl)return;
    const arenaM=MONSTERS.find(a=>a.id===m.id);const mSvg=m.svg||arenaM?.svg||'';const mAnim=m.anim||arenaM?.anim||'wo';const svgDisp=resizeSvg(mSvg,80,80);
    cardEl.style.opacity='1';
    cardEl.innerHTML='<div class="pack-reveal-card">'
      +'<div class="pack-rarity-badge prc-'+m.rarity+'">'+m.rarity.toUpperCase()+'</div>'
      +(svgDisp?'<div class="'+m.anim+'" style="margin:4px 0">'+svgDisp+'</div>':'')
      +'<div class="pack-mon-name">'+m.name+'</div>'
      +'<div class="pack-mon-power">⚡ '+m.power+' · '+m.type+'</div>'
      +'</div>'
      +'<div class="pack-counter" style="margin-top:8px;color:#c4982a;font-size:11px">Card '+(S.ri+1)+' of '+total+'</div>'
      +(S.ri<total-1
        ?'<button class="btn-p" onclick="nRev()" style="margin-top:8px">Next Card ›</button>'
        :'<button class="btn-p" onclick="cRev()" style="margin-top:8px">Add to Collection ✓</button>');
    sfx('award');
  },1100);
}

function getRarityEmoji(r){
  return r==='legendary'?'🌟':r==='epic'?'💜':r==='rare'?'💙':'💚';
}

function spawnPackSparkles(){
  const wrap=document.getElementById('packBoxWrap');
  if(!wrap)return;
  const emojis=['✨','⭐','💫','🌟','⚡'];
  for(let i=0;i<8;i++){
    const s=document.createElement('div');
    s.className='pack-sparkle';
    s.textContent=emojis[Math.floor(Math.random()*emojis.length)];
    s.style.cssText='left:'+(20+Math.random()*100)+'px;top:'+(Math.random()*80)+'px;animation-delay:'+(Math.random()*.3)+'s';
    wrap.appendChild(s);
  }
}

function nRev(){S.ri++;rReveal()}
function cRev(){
  S.rq=[];S.ri=0;S.rp='';
  const area=document.getElementById('pra');
  if(area)area.innerHTML='';
  rShop();
}
function rCol(){
  const col=S.kids[S.ck].col;
  const kidName=S.kids[S.ck].name;
  const colHeader=document.getElementById('colHeader');
  if(colHeader)colHeader.textContent=kidName+"'s Collection";
  const arenaOwned=new Set(col.filter(m=>MONSTERS.some(a=>a.id===m.id)).map(m=>m.id)).size;document.getElementById("colc").textContent=col.length+" cards · "+arenaOwned+"/"+MONSTERS.length+" fighters";
  const g=document.getElementById("mgrid");
  if(!col.length){g.innerHTML="<div class=\"es\">Open some packs! 📦<\/div>";return}
  const kidIdx=S.ck;
  // Deduplicate by id, sort power desc then name asc
  const seen2=new Set();
  const uniq=[...col].filter(m=>{if(seen2.has(m.id))return false;seen2.add(m.id);return true;});
  uniq.sort((a,b)=>b.power-a.power||a.name.localeCompare(b.name));
  g.innerHTML=uniq.map(m=>{
    const nick=getMonName(kidIdx,m);
    const hasNick=nick!==m.name;
    const rawMon=m.svg||(MONSTERS.find(a=>a.id===m.id)||{}).svg||'';const monSvg=resizeSvg(rawMon,56,56);
    const monAnim=m.anim||'wo';
    return `<div class="mc r-${m.rarity}" data-uid="${m.uid}" data-nick="${(nick||'').replace(/"/g,'&quot;')}" title="Tap to nickname" onclick="handleMonClick(this)"><div class="${monAnim}">${monSvg}<\/div><div class="mcn">${hasNick?'<span style=\"color:#FF8E53\">'+nick+'<\/span>':m.name}<\/div><div class="mcp">⚡${m.power}<\/div><\/div>`;
  }).join("");
}
function setCC(i){S.sk=i;S.shk=i;S.ck=i;S.qk=i;rKids();rCol();}
function rQuests(){
  document.getElementById("qlist").innerHTML=QUESTS.map((q,i)=>{
    const key=S.qk+"-"+i,done=S.qd[key];
    const rw=q.t==="pack"?"Free Pack":"+"+q.r+" pts";
    return"<div class=\"qi "+(done?"qc":"")+"\">"+"<div><div class=\"qn\">"+q.n+"<\/div><div class=\"qd\">"+q.d+"<\/div><\/div>"+"<div style=\"display:flex;gap:7px;align-items:center\"><span class=\"qr\">"+rw+"<\/span>"+(!done?"<button class=\"btn-s\" style=\"font-size:10px;padding:4px 9px\" onclick=\"cQ("+i+")\" >Award<\/button>":"<span style=\"font-size:10px;color:#ccc\">Done ✓<\/span>")+"<\/div><\/div>";
  }).join("");
  document.getElementById("sevts").innerHTML=EVENTS.map((e,i)=>"<div class=\"qi\"><div><div class=\"qn\">"+e.n+"<\/div><div class=\"qd\">"+e.d+"<\/div><\/div><button class=\"btn-s\" style=\"font-size:10px;padding:4px 9px;"+(S.ev===i?"background:#FFF3E0;color:#E65100;border-color:#FFB74D":"")+"\" onclick=\"togEv("+i+")\">"+(S.ev===i?"Active ✓":"Activate")+"<\/button><\/div>").join("");
}
function setQK(i){S.sk=i;S.shk=i;S.ck=i;S.qk=i;rKids();rQuests();}
function cQ(qi){
  const q=QUESTS[qi],kid=S.kids[S.qk],key=S.qk+"-"+qi;
  S.qd[key]=true;
  if(q.t==="pts"){kid.pts+=q.r;kid.earned+=q.r;toast("🎯 +"+q.r+" pts!");}
  else{kid.col.push({...RP.common[Math.floor(Math.random()*RP.common.length)],uid:Date.now()});toast("🎁 Free pack!");}
  rKids();rQuests();
}
function togEv(i){S.ev=S.ev===i?null:i;toast(S.ev!==null?EVENTS[i].n+" on!":"Event off.");rQuests();}
var tTO;
function toast(msg){
  let t=document.getElementById("toast");
  if(!t){t=document.createElement("div");t.id="toast";t.className="toast";document.body.appendChild(t)}
  t.textContent=msg;t.style.opacity="1";clearTimeout(tTO);tTO=setTimeout(()=>t.style.opacity="0",2600);
}
function st(el,name){
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  el.classList.add("active");document.getElementById("panel-"+name).classList.add("active");
  if(name==="shop"){S.shk=S.sk;rShop();}
  if(name==="collection"){S.ck=S.sk;rCol();}
  if(name==="battle"){buildGrids();renderBattleHistory();}
  if(name==="quests"){S.qk=S.sk;rQuests();}
}
// ── SAVE / LOAD ─────────────────────────────────────────────────────
const SAVE_KEY = 'mcq_save_v1';

function saveGame(){
  try{
    const data = {
      kids: S.kids.map(k=>({
        name: k.name, e: k.e, pts: k.pts, earned: k.earned,
        col: k.col, streak: k.streak, lastChoreDate: k.lastChoreDate,
        nicks: k.nicks||{}, collectionComplete: k.collectionComplete||false
      })),
      log: S.log.slice(0,50),
      qd: S.qd,
      battleHistory: S.battleHistory,
      dungeonLevel: S.dungeonLevel||0,
      ev: S.ev
    };
    localStorage.setItem(SAVE_KEY, JSON.stringify(data));
  }catch(e){ console.warn('Save failed:', e); }
}

function loadGame(){
  try{
    const raw = localStorage.getItem(SAVE_KEY);
    if(!raw) return false;
    const data = JSON.parse(raw);
    if(!data||!data.kids) return false;
    // Restore kids - merge saved data onto fresh KIDS structure
    data.kids.forEach((saved, i)=>{
      if(!S.kids[i]) return;
      S.kids[i].name = saved.name || S.kids[i].name;
      S.kids[i].e = saved.e || saved.name[0] || S.kids[i].e;
      S.kids[i].pts = saved.pts || 0;
      S.kids[i].earned = saved.earned || 0;
      S.kids[i].col = saved.col || [];
      S.kids[i].streak = saved.streak || 0;
      S.kids[i].lastChoreDate = saved.lastChoreDate || '';
      S.kids[i].nicks = saved.nicks || {};
      S.kids[i].collectionComplete = saved.collectionComplete || false;
    });
    S.log = data.log || [];
    S.qd = data.qd || {};
    S.battleHistory = data.battleHistory || [];
    S.dungeonLevel = data.dungeonLevel || 0;
    S.ev = data.ev !== undefined ? data.ev : null;
    return true;
  }catch(e){ console.warn('Load failed:', e); return false; }
}

document.addEventListener("DOMContentLoaded",function(){
  try{
    const loaded = loadGame();
    buildArches();
    buildGrids();
    resizeParticleCanvas();
    pLoop();
    updateUI();
    rKids();rChores();rLog();
    if(loaded) toast('✅ Progress loaded!');
  }catch(e){
    console.error('INIT ERROR:',e.message,e.stack);
    document.body.innerHTML='<div style="padding:20px;font-family:monospace;background:#1a0030;color:#FF6B6B;font-size:13px;white-space:pre-wrap">INIT ERROR: '+e.message+'\n\n'+e.stack+'</div>';
  }
});

