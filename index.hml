<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monster Chore Quest</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Segoe UI",system-ui,sans-serif;background:#0f0a1a;min-height:100vh;color:#e8e0f8}

/* ── APP WRAPPER ── */
.app{max-width:960px;margin:0 auto;padding:16px;position:relative;z-index:1}

/* ── SUBTLE BG GLOW ── */
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 30%,rgba(138,43,226,0.12) 0%,transparent 60%),radial-gradient(ellipse at 80% 70%,rgba(255,107,107,0.08) 0%,transparent 60%);pointer-events:none;z-index:0}

/* ── HEADER ── */
.header{text-align:center;padding:18px 0 12px}
.header h1{font-size:32px;font-weight:900;letter-spacing:-1px;background:linear-gradient(135deg,#ff6b6b,#ffd93d,#6bcb77,#4d96ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 2px 8px rgba(255,107,107,0.3))}
.header p{font-size:12px;color:#7060a0;margin-top:4px;-webkit-text-fill-color:#7060a0}

/* ── KID CARDS ── */
.kids-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.kid-card{border-radius:22px;padding:16px;text-align:center;position:relative;overflow:hidden;cursor:pointer;transition:transform .2s,box-shadow .2s;box-shadow:0 6px 24px rgba(0,0,0,0.5)}
.kid-card:hover{transform:translateY(-4px);box-shadow:0 10px 32px rgba(0,0,0,0.6)}
.k0{background:linear-gradient(145deg,#c0392b,#ff4081);border:2px solid rgba(255,107,107,0.5)}
.k1{background:linear-gradient(145deg,#0077aa,#00acc1);border:2px solid rgba(38,198,218,0.5)}
.k2{background:linear-gradient(145deg,#6a1b9a,#ab47bc);border:2px solid rgba(171,71,188,0.5)}
.kid-selected{outline:3px solid #FFD600!important;box-shadow:0 0 0 3px #FFD600,0 8px 28px rgba(255,214,0,0.35)!important;transform:translateY(-4px)!important}
.kid-avatar{width:48px;height:48px;border-radius:50%;background:rgba(0,0,0,0.25);margin:0 auto 6px;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;color:white;border:2px solid rgba(255,255,255,0.3)}
.kid-name{font-size:14px;font-weight:800;color:white;text-shadow:0 1px 4px rgba(0,0,0,0.5)}
.kid-level{font-size:10px;color:rgba(255,255,255,0.75);margin-bottom:6px}
.kid-points{font-size:30px;font-weight:900;color:white;line-height:1;text-shadow:0 2px 8px rgba(0,0,0,0.4)}
.kid-pts-label{font-size:9px;color:rgba(255,255,255,0.65);margin-top:2px}
.xbar-w{background:rgba(0,0,0,0.3);border-radius:6px;height:7px;margin-top:10px;overflow:hidden}
.xbar{height:7px;border-radius:6px;background:rgba(255,255,255,0.85);transition:width .5s;box-shadow:0 0 6px rgba(255,255,255,0.4)}

/* ── TABS ── */
.tabs{display:flex;gap:5px;background:#1a1030;border-radius:18px;padding:5px;margin-bottom:14px;box-shadow:0 4px 16px rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.06)}
.tab{flex:1;padding:9px 4px;text-align:center;font-size:11px;font-weight:700;border-radius:12px;cursor:pointer;color:#6050a0;transition:all .2s}
.tab.active{background:linear-gradient(135deg,#c0392b,#ff6b00);color:white;box-shadow:0 3px 10px rgba(192,57,43,0.5);transform:translateY(-1px)}
.tab:hover:not(.active){background:rgba(255,255,255,0.06);color:#b090e0}
.tab-icon{font-size:16px;display:block;margin-bottom:2px}
.panel{display:none}.panel.active{display:block}

/* ── CARDS ── */
.card{background:#1a1030;border-radius:18px;padding:16px;margin-bottom:12px;box-shadow:0 4px 20px rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.08)}
.card:hover{border-color:rgba(255,255,255,0.12)}
.sl{font-size:10px;font-weight:800;color:#6050a0;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}

/* ── KID PILLS ── */
.ksp{display:flex;gap:7px;margin-bottom:10px;flex-wrap:wrap}
.kpill{padding:6px 14px;border-radius:18px;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:#8070b0;transition:all .15s}
.ak0{background:#c0392b!important;color:white!important;border-color:#ff4081!important;box-shadow:0 2px 8px rgba(192,57,43,0.4)!important}
.ak1{background:#0077aa!important;color:white!important;border-color:#00acc1!important;box-shadow:0 2px 8px rgba(0,119,170,0.4)!important}
.ak2{background:#6a1b9a!important;color:white!important;border-color:#ab47bc!important;box-shadow:0 2px 8px rgba(106,27,154,0.4)!important}

/* ── CHORES ── */
.chore-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.chore-btn{background:#211540;border:1.5px solid rgba(255,255,255,0.1);border-radius:14px;padding:11px 13px;text-align:left;cursor:pointer;transition:all .18s;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.chore-btn:hover{border-color:#ff6b00;background:#2d1a50;transform:scale(1.02);box-shadow:0 4px 14px rgba(255,107,0,0.2)}
.chore-btn:active{transform:scale(.97)}
.cbname{font-size:12px;font-weight:700;color:#e8e0f8;margin-bottom:3px}
.cbpts{font-size:12px;font-weight:900;color:#FFD600}
.cbsz{font-size:9px;padding:2px 8px;border-radius:8px;display:inline-block;margin-bottom:5px;font-weight:800}
.szs{background:rgba(76,175,80,0.2);color:#69f0ae}.szm{background:rgba(255,152,0,0.2);color:#ffcc02}.szb{background:rgba(244,67,54,0.2);color:#ff6b6b}
.log-list{max-height:150px;overflow-y:auto}
.log-item{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-size:11px;color:#7060a0}
.log-item:last-child{border-bottom:none}
.lp{font-weight:800;color:#FFD600}
.es{text-align:center;color:#4030608;font-size:13px;padding:24px;color:#5040808;color:#504080;line-height:1.6}

/* ── BUTTONS ── */
button{cursor:pointer;font-family:inherit}
.btn-p{background:linear-gradient(135deg,#c0392b,#ff6b00);color:white;border:none;border-radius:12px;padding:10px 20px;font-size:12px;font-weight:800;box-shadow:0 3px 12px rgba(192,57,43,0.4);transition:all .18s}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(192,57,43,0.5)}
.btn-s{background:rgba(255,255,255,0.06);color:#b090e0;border:1.5px solid rgba(255,255,255,0.1);border-radius:10px;padding:7px 14px;font-size:11px;font-weight:700;transition:all .15s}
.btn-s:hover{border-color:#ab47bc;color:#e0b0ff}

/* ── SHOP ── */
.pack-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.pack-card{border:1.5px solid rgba(255,255,255,0.1);border-radius:18px;padding:16px;cursor:pointer;background:#211540;transition:all .2s;text-align:center;box-shadow:0 3px 12px rgba(0,0,0,0.3)}
.pack-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,0.5);border-color:rgba(255,214,0,0.4)}
.pack-card:active{transform:translateY(0)}
.pack-card:nth-child(1){border-color:rgba(144,202,249,0.3)}
.pack-card:nth-child(2){border-color:rgba(206,147,216,0.3)}
.pack-card:nth-child(3){border-color:rgba(255,214,0,0.3)}
.pack-card:nth-child(4){border-color:rgba(255,128,171,0.3)}
.pack-icon{font-size:32px;margin-bottom:5px;display:block}
.pack-name{font-size:13px;font-weight:800;color:#e8e0f8;margin-bottom:3px}
.pack-cost{font-size:14px;font-weight:900;color:#FFD600}
.pack-odds{font-size:9px;color:#6050a0;margin-top:4px;line-height:1.5}
.pack-locked{opacity:.35;pointer-events:none}
#shpts{font-size:13px;color:#FFD600;font-weight:800;background:rgba(255,214,0,0.1);padding:3px 10px;border-radius:10px;border:1px solid rgba(255,214,0,0.2)}

/* ── COLLECTION ── */
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px}
.mc{border:1.5px solid rgba(255,255,255,0.1);border-radius:12px;padding:8px 5px;text-align:center;background:#1a1030;transition:transform .18s;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.mc:hover{transform:translateY(-3px);box-shadow:0 6px 16px rgba(0,0,0,0.5);border-color:rgba(255,255,255,0.2)}
.mc.r-rare{border-color:rgba(144,202,249,0.4)}
.mc.r-epic{border-color:rgba(206,147,216,0.5)}
.mc.r-legendary{border-color:#FFD600;border-width:2px;box-shadow:0 0 10px rgba(255,214,0,0.2)}
.mcn{font-size:9px;font-weight:700;color:#c0b0e8;line-height:1.2}
.mcp{font-size:9px;font-weight:800;color:#FFD600}
#colc{background:rgba(255,214,0,0.1);color:#FFD600;padding:3px 10px;border-radius:10px;font-size:10px;font-weight:800;border:1px solid rgba(255,214,0,0.2);white-space:nowrap}
#colHeader{font-size:13px!important;font-weight:800!important;color:#e8e0f8!important;text-transform:none!important;letter-spacing:0!important}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#c0392b,#ffd93d);color:white;padding:12px 24px;border-radius:18px;font-size:13px;font-weight:800;box-shadow:0 6px 24px rgba(0,0,0,0.5);transition:opacity .4s;pointer-events:none;z-index:9000}

/* ── QUESTS ── */
.qi{display:flex;justify-content:space-between;align-items:center;padding:10px;border-bottom:1px solid rgba(255,255,255,0.06);gap:8px;border-radius:10px;margin-bottom:4px;background:rgba(255,255,255,0.03);transition:all .15s}
.qi:hover{background:rgba(255,255,255,0.06)}
.qc{opacity:.4}
.qn{font-size:12px;font-weight:800;color:#e8e0f8}
.qd{font-size:10px;color:#6050a0;margin-top:2px}
.qr{font-size:11px;font-weight:800;color:#FFD600;background:rgba(255,214,0,0.1);padding:4px 10px;border-radius:10px;border:1px solid rgba(255,214,0,0.2);white-space:nowrap}

/* ── HP BARS ── */
.hp-row{display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:start;margin-bottom:10px}
.hp-side{background:rgba(0,0,0,0.3);border:1px solid rgba(255,214,0,0.15);border-radius:8px;padding:8px}
.hp-team-label{font-size:9px;font-weight:900;color:#FFD600;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.hp-monster{margin-bottom:6px}
.hp-name{font-size:9px;font-weight:700;color:rgba(255,255,255,0.75);margin-bottom:2px}
.hp-wrap{background:rgba(0,0,0,0.5);border-radius:4px;height:7px;overflow:hidden;margin-bottom:2px}
.hp-bar{height:100%;border-radius:4px;transition:width .4s}
.hi{background:linear-gradient(90deg,#2e7d32,#69f0ae)}
.hp-bar.md{background:linear-gradient(90deg,#e65100,#ffcc02)}
.lo{background:linear-gradient(90deg,#c62828,#ff5252)}
.hp-num{font-size:8px;color:rgba(255,255,255,0.4)}
.dead-txt{color:#ff5252!important;font-weight:800}
.dead-label{opacity:.4;text-decoration:line-through}
.vs-mid{text-align:center;font-size:18px;color:#FFD600;padding-top:10px}

/* ── BATTLE ── */
.mode-tabs{display:flex;gap:6px;margin-bottom:10px}
.mode-tab{flex:1;padding:8px;text-align:center;font-size:11px;font-weight:700;border-radius:10px;cursor:pointer;background:#1a1030;color:#6050a0;border:1.5px solid rgba(255,255,255,0.08);transition:all .15s}
.mode-tab.active{background:linear-gradient(135deg,#c0392b,#ff6b00);color:white;border-color:transparent;box-shadow:0 3px 10px rgba(192,57,43,0.4)}

/* ── PICKER ── */
.picker-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.picker-col{background:#1a1030;border-radius:14px;padding:12px;border:1.5px solid rgba(255,255,255,0.08)}
.picker-label{font-size:11px;font-weight:800;color:#e8e0f8;margin-bottom:6px}
.picker-grid{display:flex;flex-wrap:wrap;gap:6px;max-height:220px;overflow-y:auto}
.pc{border:1.5px solid rgba(255,255,255,0.1);border-radius:10px;padding:5px;cursor:pointer;text-align:center;transition:all .15s;background:#211540;width:74px}
.pc:hover{border-color:#FFD600;transform:scale(1.05)}
.pc.sel{border-color:#ff6b6b;background:rgba(192,57,43,0.2);box-shadow:0 0 8px rgba(255,107,107,0.3)}
.pc-name{font-size:8px;font-weight:700;color:#c0b0e8;margin-top:2px;line-height:1.2}
.pc-pwr{font-size:8px;font-weight:800;color:#FFD600}
#plL,#plR{font-size:9px;color:#6050a0;font-weight:600}
#cL,#cR{font-size:9px;font-weight:700;color:#FFD600}

/* ── FIGHT BUTTON ── */
.fight-btn{width:100%;padding:14px;background:linear-gradient(135deg,#c0392b,#ff6b00,#ffd93d);border:none;border-radius:14px;font-size:16px;font-weight:900;color:white;letter-spacing:1px;box-shadow:0 5px 20px rgba(192,57,43,0.5);transition:all .2s;text-transform:uppercase}
.fight-btn:hover:not(:disabled){transform:translateY(-3px);box-shadow:0 8px 28px rgba(192,57,43,0.6)}
.fight-btn:disabled{opacity:.4;cursor:not-allowed}

/* ── COLOSSEUM ── */
.colosseum{position:relative;background:linear-gradient(180deg,#0a0418 0%,#1a0840 50%,#0a0418 100%);border-radius:18px;overflow:hidden;margin-bottom:10px;min-height:220px;border:1.5px solid rgba(255,214,0,0.2)}
.floor{position:absolute;bottom:0;left:0;right:0;height:36%;background:linear-gradient(180deg,#1a0a04,#0a0400);border-top:1px solid rgba(255,214,0,0.1)}
.arches{position:absolute;inset:0;pointer-events:none}
.arch{position:absolute;bottom:34%;width:8%;border-radius:50% 50% 0 0;background:rgba(255,214,0,0.04);border:1px solid rgba(255,214,0,0.08)}
.arena-title h2{position:relative;z-index:2;text-align:center;padding:10px 0 0;font-size:14px;font-weight:900;color:#FFD600;letter-spacing:2px;text-transform:uppercase;text-shadow:0 0 20px rgba(255,214,0,0.4)}
.fighters{position:relative;z-index:2;display:flex;align-items:flex-end;justify-content:space-between;padding:0 16px 8px;min-height:130px}
.team-slot{display:flex;gap:4px;align-items:flex-end;flex-wrap:wrap;max-width:46%}
.vs-badge{flex:0 0 auto;display:flex;align-items:center;justify-content:center;padding:0 4px}
.vs-txt{font-size:20px;font-weight:900;color:#FFD600;text-shadow:0 0 16px rgba(255,214,0,0.6)}
.fighter{display:flex;flex-direction:column;align-items:center;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.8))}
.fighter-label{font-size:8px;font-weight:700;color:rgba(255,255,255,0.65);margin-top:2px;text-align:center;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fighter-pwr{font-size:8px;font-weight:800;color:#FFD600}
.hit-layer{position:absolute;inset:0;z-index:3;pointer-events:none;overflow:hidden}
.particle-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:4;pointer-events:none}

/* ── BATTLE LOG ── */
.battle-log-wrap{background:rgba(0,0,0,0.4);border-radius:10px;padding:8px;margin-bottom:10px;max-height:80px;overflow-y:auto;border:1px solid rgba(255,255,255,0.06)}
.battle-log{font-size:10px;font-family:monospace;color:rgba(255,255,255,0.55)}
.li{margin-right:5px}
.lm.dmg{color:#FFD600}.lm.crit{color:#ff5252}.lm.win{color:#69f0ae}.lm.miss{color:#6050a0}.lm.upset{color:#CE93D8}.lm.hl{color:#4DD0E1}

/* ── BATTLE HISTORY ── */
#battleHistoryList .bh-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-size:11px;gap:6px}
#battleHistoryList .bh-winner{font-weight:800;flex:1}
#battleHistoryList .bh-vs{color:#4030608;color:#403060}
#battleHistoryList .bh-loser{color:#6050a0;flex:1;text-align:right}
#battleHistoryList .bh-date{color:#4030808;color:#403060;font-size:9px;white-space:nowrap}

/* ── VICTORY OVERLAY ── */
.victory-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,8,0.92);z-index:6000;align-items:center;justify-content:center}
.victory-overlay.show{display:flex}
.victory-card{background:linear-gradient(145deg,#0d0620,#1a0840);border:2px solid #FFD600;border-radius:22px;padding:28px 36px;text-align:center;box-shadow:0 0 60px rgba(255,214,0,0.25)}
.victory-trophy{font-size:52px;display:block;margin-bottom:8px}
.victory-title{font-size:14px;font-weight:900;color:#FFD600;text-transform:uppercase;letter-spacing:3px}
.victory-name{font-size:22px;font-weight:900;color:white;margin:6px 0}
.victory-sub{font-size:11px;color:#a090d0;margin-bottom:14px}
.victory-upset{display:none;font-size:12px;font-weight:700;color:#CE93D8;margin-bottom:10px}
.victory-upset.show{display:block}
.victory-btn{padding:11px 28px;background:linear-gradient(135deg,#FFD600,#FF8C00);border:none;border-radius:12px;font-size:13px;font-weight:900;color:#0d0620;cursor:pointer;letter-spacing:1px}

/* ── UPSET FLASH ── */
.upset-flash{display:none;position:fixed;top:40%;left:50%;transform:translate(-50%,-50%);font-size:28px;font-weight:900;color:#FFD600;text-shadow:0 0 30px #FFD600;z-index:5000;pointer-events:none;white-space:nowrap}
.upset-flash.show{display:block;animation:flash .4s ease-in-out}
@keyframes flash{0%,100%{opacity:0}50%{opacity:1}}

/* ── PACK REVEAL ── */
.pack-open-overlay{position:fixed;inset:0;background:rgba(0,0,8,0.96);z-index:7000;display:flex;align-items:center;justify-content:center;flex-direction:column}
.pack-box-wrap{position:relative;width:140px;height:140px;margin-bottom:24px}
.pack-box-lid{position:absolute;top:0;left:50%;transform:translateX(-50%);width:110px;height:55px;background:linear-gradient(145deg,#2a1060,#4a1090);border:2px solid #FFD600;border-radius:10px 10px 0 0;display:flex;align-items:center;justify-content:center;font-size:28px;transform-origin:bottom center;transition:transform .4s ease-in-out;z-index:2}
.pack-box-lid.open{transform:translateX(-50%) rotateX(-120deg)}
.pack-box-body{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:110px;height:70px;background:linear-gradient(145deg,#1a0840,#2d1060);border:2px solid rgba(255,214,0,0.5);border-radius:0 0 10px 10px}
.pack-box-star{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);font-size:36px;transition:transform .3s cubic-bezier(.34,1.56,.64,1);z-index:3}
.pack-box-star.show{transform:translate(-50%,-50%) scale(1)}
.pack-reveal-card{background:linear-gradient(145deg,#0d0620,#1a0840);border:2px solid #FFD600;border-radius:18px;padding:16px;text-align:center;min-width:160px;animation:winpop .4s cubic-bezier(.34,1.56,.64,1)}
.pack-rarity-badge{font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:2px;padding:3px 12px;border-radius:20px;display:inline-block;margin-bottom:6px}
.prc-common{background:rgba(255,255,255,0.1);color:#c0b0e8}
.prc-rare{background:rgba(144,202,249,0.2);color:#90caf9}
.prc-epic{background:rgba(206,147,216,0.2);color:#ce93d8}
.prc-legendary{background:rgba(255,214,0,0.2);color:#FFD600;border:1px solid rgba(255,214,0,0.4)}
.pack-mon-name{font-size:14px;font-weight:800;color:white;margin-top:4px}
.pack-mon-power{font-size:11px;color:#FFD600;margin-top:2px}
.pack-sparkle{position:absolute;font-size:16px;animation:sparkle-fly .8s ease-out forwards;pointer-events:none}
@keyframes sparkle-fly{0%{opacity:1;transform:scale(.5)}100%{opacity:0;transform:scale(1.4) translateY(-40px)}}

/* ── ANIMATIONS ── */
@keyframes wo{0%,100%{transform:rotate(-4deg) scale(1)}50%{transform:rotate(4deg) scale(1.05)}}
@keyframes af{0%,100%{transform:translateY(0)}40%{transform:translateY(-6px) scale(1.08)}80%{transform:translateY(2px)}}
@keyframes ab{0%,100%{transform:scaleX(1)}50%{transform:scaleX(-1)}}
@keyframes aw{0%,100%{transform:translateX(0)}50%{transform:translateX(5px)}}
@keyframes ap{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
@keyframes as{0%,100%{transform:rotate(0)}25%{transform:rotate(-5deg)}75%{transform:rotate(5deg)}}
@keyframes ay{0%,100%{transform:skewX(0)}50%{transform:skewX(4deg)}}
@keyframes lunge{0%,100%{transform:translateX(0)}40%{transform:translateX(20px) scaleX(1.1)}}
@keyframes lungel{0%,100%{transform:translateX(0)}40%{transform:translateX(-20px) scaleX(1.1)}}
@keyframes fhurt{0%,100%{filter:none}50%{filter:brightness(3) saturate(0)}}
@keyframes winpop{0%{transform:scale(.6)}60%{transform:scale(1.1)}100%{transform:scale(1)}}
.wo{animation:wo 2s ease-in-out infinite}.af{animation:af 1.4s ease-in-out infinite}.ab{animation:ab 1.2s ease-in-out infinite}.aw{animation:aw 1.8s ease-in-out infinite}.ap{animation:ap 1.6s ease-in-out infinite}.as{animation:as 2s ease-in-out infinite}.ay{animation:ay 2.2s ease-in-out infinite}

/* ── HIT FX ── */
.hit-fx{position:absolute;font-size:13px;font-weight:900;pointer-events:none;text-shadow:0 1px 4px rgba(0,0,0,0.8);animation:hit-rise .8s ease-out forwards;z-index:10}
@keyframes hit-rise{0%{transform:translateY(0) scale(1);opacity:1}100%{transform:translateY(-44px) scale(1.3);opacity:0}}

/* ── FIGHTER STATES ── */
.fighter.dying{animation:squish .15s ease-in-out!important}
.fighter.exploded{opacity:0!important;pointer-events:none}
@keyframes squish{0%{transform:scale(1)}50%{transform:scale(1.4,.6)}100%{transform:scale(.8,1.2)}}
@keyframes shake{0%,100%{transform:translateX(0)}15%{transform:translateX(-7px)}30%{transform:translateX(7px)}45%{transform:translateX(-5px)}60%{transform:translateX(5px)}75%{transform:translateX(-3px)}90%{transform:translateX(3px)}}
.shaking{animation:shake .35s ease-in-out!important}

/* ── EXPLOSION ── */
.expl-flash{position:absolute;inset:-20px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,0.9) 0%,transparent 70%);animation:flash-out .2s ease-out forwards;z-index:20}
@keyframes flash-out{0%{opacity:1;transform:scale(.4)}100%{opacity:0;transform:scale(2)}}
.expl-fireball{position:absolute;width:60px;height:60px;margin:-30px 0 0 -30px;border-radius:50%;background:radial-gradient(circle,#fff 0%,#FFD600 30%,#FF6D00 60%,transparent 80%);animation:fireball-out .4s ease-out forwards;z-index:19}
@keyframes fireball-out{0%{opacity:1;transform:scale(.3)}100%{opacity:0;transform:scale(2.2)}}
.expl-sw{position:absolute;border-radius:50%;border:3px solid currentColor;width:40px;height:40px;margin:-20px 0 0 -20px;animation:sw-out .5s ease-out forwards;z-index:18}
.expl-sw.s1{color:#FF6D00;animation-delay:.02s;width:50px;height:50px;margin:-25px 0 0 -25px}
.expl-sw.s2{color:#FFD600;animation-delay:.06s;width:70px;height:70px;margin:-35px 0 0 -35px}
.expl-sw.s3{color:#FF3D00;animation-delay:.1s;width:90px;height:90px;margin:-45px 0 0 -45px}
@keyframes sw-out{0%{opacity:.9;transform:scale(.2)}100%{opacity:0;transform:scale(1)}}
.expl-ko{position:absolute;font-size:22px;font-weight:900;color:white;text-shadow:0 0 12px #FF1744;top:-36px;left:50%;transform:translateX(-50%);animation:ko-pop .7s cubic-bezier(.34,1.56,.64,1) forwards;z-index:22}
@keyframes ko-pop{0%{opacity:0;transform:translateX(-50%) scale(.3)}40%{opacity:1;transform:translateX(-50%) scale(1.3)}100%{opacity:0;transform:translateX(-50%) translateY(-30px) scale(1)}}
.expl-ghost{position:absolute;font-size:28px;top:-20px;left:50%;transform:translateX(-50%);animation:ghost-rise .9s ease-out forwards;z-index:21}
@keyframes ghost-rise{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(-60px)}}
.expl-debris{position:absolute;top:50%;left:50%;border-radius:2px;animation:debris-fly var(--dur,.5s) cubic-bezier(0.1,0.6,0.3,1) forwards}
@keyframes debris-fly{0%{opacity:1;transform:translate(-50%,-50%) rotate(0deg) scale(1)}100%{opacity:0;transform:translate(calc(-50% + var(--dx)),calc(-50% + var(--dy))) rotate(var(--rot)) scale(0)}}
.expl-emoji{position:absolute;top:50%;left:50%;animation:emoji-fly var(--dur,.6s) ease-out var(--delay,0s) forwards;z-index:20}
@keyframes emoji-fly{0%{opacity:1;transform:translate(-50%,-50%) scale(.5)}100%{opacity:0;transform:translate(calc(-50% + var(--dx)),calc(-50% + var(--dy))) rotate(var(--rot)) scale(1.2)}}
.expl-smoke{position:absolute;top:50%;left:50%;border-radius:50%;animation:smoke-puff var(--dur,.7s) ease-out var(--delay,0s) forwards}
@keyframes smoke-puff{0%{opacity:.7;transform:translate(-50%,-50%) scale(.3)}100%{opacity:0;transform:translate(calc(-50% + var(--dx)),calc(-50% + var(--dy))) scale(1.8)}}
.expl-crater{position:absolute;width:80px;height:30px;margin:-15px 0 0 -40px;border-radius:50%;animation:crater-fade .8s ease-out .2s forwards}
@keyframes crater-fade{0%{opacity:.8}100%{opacity:0}}

/* ── CONFETTI ── */
@keyframes confettiFall{0%{transform:translateY(-10px) rotate(0deg);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}

/* ── DUNGEON ── */
.dq-overlay{display:none;position:fixed;inset:0;z-index:8000;flex-direction:column}
.dq-overlay.show{display:flex}
.dq-bg{flex:1;position:relative;overflow:hidden;background:linear-gradient(180deg,#0a0418 0%,#150828 40%,#1a0a04 70%,#0a0600 100%)}
.dq-hud{background:#0d0620;border-top:2px solid rgba(255,214,0,0.2);padding:8px 12px;flex-shrink:0;overflow:hidden;}
.dq-floor-lbl{font-size:11px;font-weight:900;color:#FFD600;text-transform:uppercase;letter-spacing:2px;margin-bottom:6px}
.dq-hud-hero{display:flex;flex-direction:column;gap:3px;padding:6px 8px;min-width:110px;max-width:160px;flex:0 0 auto;background:rgba(255,255,255,0.06);border-radius:8px;border:1px solid rgba(255,255,255,0.1)}
.dq-hud-hero.dead{opacity:.35}


.dq-hud-hp-wrap{background:rgba(0,0,0,0.5);border-radius:3px;height:5px;overflow:hidden}
.dq-hud-hp{height:100%;border-radius:3px;transition:width .3s}.dq-hud-hp.hi{background:#69f0ae}.dq-hud-hp.lo{background:#ff5252}

.dq-log{font-size:10px;font-family:monospace;max-height:80px;overflow-y:auto;color:rgba(255,255,255,0.55);margin-top:4px}
.dq-log div{padding:1px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.dq-flee-btn{margin-top:6px;width:100%;padding:8px;background:rgba(255,50,50,0.15);border:1px solid rgba(255,50,50,0.3);border-radius:8px;color:#ff6b6b;font-size:12px;font-weight:700;cursor:pointer}
.dq-flee-btn:hover{background:rgba(255,50,50,0.25)}
.dq-field{position:absolute;bottom:60px;left:0;right:0;display:flex;justify-content:space-between;align-items:flex-end;padding:0 20px}
.dq-unit{display:flex;flex-direction:column;align-items:center;gap:2px;transition:transform .2s}
.dq-fhp-bar-wrap{width:50px;height:5px;background:rgba(0,0,0,0.5);border-radius:3px;overflow:hidden;margin-bottom:2px}
.dq-fhp-bar{height:100%;border-radius:3px;transition:width .3s}.dq-fhp-bar.hi{background:#69f0ae}.dq-fhp-bar.lo{background:#ff5252}
.dq-fname{font-size:8px;font-weight:700;color:rgba(255,255,255,0.7);text-align:center;max-width:70px}
.dq-unit.idle{animation:ap 2s ease-in-out infinite}
.dq-unit.atk-right{animation:lunge .35s ease-in-out}
.dq-unit.atk-left{animation:lungel .35s ease-in-out}
.dq-unit.hurting{animation:fhurt .3s}
.dq-unit.dead-unit{opacity:.2;filter:grayscale(1)}
.dq-hit{font-size:20px;pointer-events:none;animation:hit-rise .8s ease-out forwards;z-index:10}
.dq-hit-num{font-size:12px;font-weight:900;pointer-events:none;animation:hit-rise .8s ease-out forwards;z-index:10;text-shadow:0 1px 4px rgba(0,0,0,.8)}
.dq-result{display:none;position:absolute;inset:0;background:rgba(0,0,8,.9);align-items:center;justify-content:center;z-index:5}
.dq-result.show{display:flex}
.dq-result-card{background:linear-gradient(145deg,#0d0620,#1a0840);border:2px solid #FFD600;border-radius:20px;padding:28px 36px;text-align:center}
.dq-result-card div{color:white;font-weight:800;margin-bottom:6px}
.dq-result-btn{margin-top:10px;padding:10px 24px;background:linear-gradient(135deg,#FFD600,#FF8C00);border:none;border-radius:10px;font-size:13px;font-weight:900;color:#0d0620;cursor:pointer}

/* ── BADGE UTILS ── */
.badge-common{background:rgba(255,255,255,0.08);color:#c0b0e8}
.badge-rare{background:rgba(144,202,249,0.15);color:#90caf9}
.badge-epic{background:rgba(206,147,216,0.15);color:#ce93d8}
.badge-legendary{background:rgba(255,214,0,0.15);color:#FFD600;border:1px solid rgba(255,214,0,0.3)}

.dq-pick-card{
  display:flex;flex-direction:column;align-items:center;gap:1px;
  padding:5px 3px;border-radius:10px;cursor:pointer;
  border:2px solid rgba(255,214,0,0.15);
  background:rgba(255,255,255,0.04);
  transition:all .15s;min-width:54px;
}
.dq-pick-card:hover{border-color:rgba(255,214,0,0.4);background:rgba(255,214,0,0.06);}
.dq-pick-card.selected{
  border-color:#FFD600;
  background:rgba(255,214,0,0.12);
  box-shadow:0 0 10px rgba(255,214,0,0.3);
}

.bad-btn{background:linear-gradient(135deg,#fff5f5,#fff0f0)!important;border-color:#ffcccc!important;}
.bad-btn .cbname{color:#cc2222!important;}
.bad-btn .cbsz{background:#ffe0e0!important;color:#cc2222!important;}
.bad-btn:hover{border-color:#ff6b6b!important;background:linear-gradient(135deg,#ffe8e8,#ffd8d8)!important;}
.bad-pts{color:#e53935!important;}
.lp-neg{font-weight:800;color:#e53935;}






#dqHeroes{display:flex;flex-direction:row;gap:8px;overflow-x:auto;padding:4px 0 6px;}
.dq-hud-name{font-size:11px;font-weight:800;color:#FFD600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.dq-hud-mon{font-size:9px;color:#c4a8e0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px;}
.dq-hud-hpnum{font-size:8px;color:#9080c0;margin-top:1px;}
.dq-floor-lbl{font-size:11px;font-weight:900;color:#FFD600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
.dq-log{font-size:10px;font-family:monospace;max-height:70px;overflow-y:auto;color:rgba(255,255,255,0.6);line-height:1.4;}

/* ── TREASURE CHEST ── */
.dq-chest-row{display:flex;gap:12px;justify-content:center;margin:12px 0;flex-wrap:wrap;}
.dq-chest{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;transition:transform .15s;}
.dq-chest:hover{transform:scale(1.08);}
.dq-chest-box{font-size:38px;animation:chest-bounce .6s ease-in-out infinite alternate;}
.dq-chest.opened .dq-chest-box{animation:chest-open .4s ease-out forwards;}
.dq-chest-label{font-size:10px;font-weight:700;color:#c4982a;}
.dq-chest-reveal{font-size:11px;font-weight:800;text-align:center;max-width:80px;line-height:1.3;}
@keyframes chest-bounce{0%{transform:translateY(0) rotate(-3deg)}100%{transform:translateY(-4px) rotate(3deg)}}
@keyframes chest-open{0%{transform:scale(1) rotate(0)}30%{transform:scale(1.4) rotate(-8deg)}60%{transform:scale(1.2) rotate(6deg)}100%{transform:scale(1) rotate(0)}}
@keyframes chest-reward-pop{0%{transform:scale(0) translateY(10px);opacity:0}60%{transform:scale(1.2) translateY(-4px);opacity:1}100%{transform:scale(1) translateY(0);opacity:1}}

.szb-s{background:#ffe8e8;color:#cc2222;font-size:9px;padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:5px;font-weight:800;}
.szb-m{background:#ffd0d0;color:#aa1111;font-size:9px;padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:5px;font-weight:800;}
.szb-b{background:#ffb8b8;color:#880000;font-size:9px;padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:5px;font-weight:800;}
</style>
  
</head>
<body>
<div class="app">
  <div class="header" style="position:relative;">
  <button id="castBtn" onclick="startCast()" title="Cast to TV" style="position:absolute;right:0;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:22px;opacity:0.6;display:none" title="Cast to TV">📺</button><h1>⚡ Monster Chore Quest ⚡</h1><p>Do chores · earn points · collect 150 silly monsters!</p></div>
  <div class="kids-grid" id="kg"></div>
  <div class="tabs">
    <div class="tab active" onclick="st(this,'chores')"><span class="tab-icon">🧹</span>Chores</div>
    <div class="tab" onclick="st(this,'shop')"><span class="tab-icon">🛍️</span>Shop</div>
    <div class="tab" onclick="st(this,'collection')"><span class="tab-icon">📦</span>Collection</div>
    <div class="tab" onclick="st(this,'battle')"><span class="tab-icon">⚔️</span>Battle</div>
    <div class="tab" onclick="st(this,'quests')"><span class="tab-icon">🎯</span>Quests</div>
  </div>
  <div class="panel active" id="panel-chores">
    <div class="card"><div class="sl">🧹 Award a Chore</div><div class="chore-grid" id="cgrid"></div></div>
    <div class="card"><div class="sl">😤 Bad Behavior</div><div class="chore-grid" id="bgrid"></div></div>
    <div class="card"><div class="sl">📋 Activity Log</div><div class="log-list" id="alog"><div class="es">No chores yet! 🌟</div></div></div>
  </div>
  <div class="panel" id="panel-shop">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <div class="sl" style="margin-bottom:0">Packs</div>
        <div id="shpts" style="font-size:13px;color:#ff6b00;font-weight:800;background:#fff3e0;padding:4px 12px;border-radius:12px;border:1.5px solid #ffd0a0"></div>
      </div>
      <div class="pack-grid" id="pgrid"></div>
    </div>
    <div id="pra"></div>
  </div>
  <div class="panel" id="panel-collection">
    <div class="card"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><div><div class="sl" style="margin-bottom:0" id="colHeader">Collection</div><div style="font-size:9px;color:#bbb;font-style:italic;margin-top:1px">tap monster to nickname</div></div><button onclick="openFusion()" style="padding:4px 12px;background:linear-gradient(135deg,#7B1FA2,#E91E63);border:none;border-radius:10px;font-size:10px;font-weight:800;color:white;cursor:pointer">🔮 Fuse</button><div id="colc"></div></div><div id="mgrid"></div></div>
  </div>
  <div class="panel" id="panel-battle">
<div class="mode-tabs">
  <div class="mode-tab active" onclick="setMode('1v1',this)">1v1 Duel</div>
  <div class="mode-tab" onclick="setMode('team',this)">Team Battle (3v3)</div>
</div>

<!-- Pure CSS Colosseum — no canvas -->
<div class="colosseum" id="colosseum">
  <div class="arches" id="arches"></div>
  <div class="floor"></div>
  <div class="arena-title"><h2>⚔ The Colosseum ⚔</h2></div>
  <div class="fighters">
    <div class="team-slot left" id="slot-L"></div>
    <div class="vs-badge"><div class="vs-txt">VS</div></div>
    <div class="team-slot right" id="slot-R"></div>
  </div>
  <div class="hit-layer" id="hit-layer"></div>
  <canvas class="particle-canvas" id="pCanvas"></canvas>
</div>


  <!-- HP bars -->
  <div class="hp-row">
    <div class="hp-side" id="hp-side-L"><div class="hp-team-label" id="lL">Team 1</div></div>
    <div class="vs-mid">⚔</div>
    <div class="hp-side" id="hp-side-R"><div class="hp-team-label" id="lR">Team 2</div></div>
  </div>

  <!-- Battle log -->
  <div class="battle-log-wrap"><div id="blog" class="battle-log"></div></div>

  <!-- Picker grids -->
  <div class="picker-row">
    <div class="picker-col">
      <div class="picker-label" id="lblL">Left Fighter</div>
      <div style="font-size:9px;color:#c4982a;margin-bottom:4px"><span id="plL">fighter power</span> · <span id="cL">0 / 1 selected</span></div>
      <div class="picker-grid" id="gL"></div>
    </div>
    <div class="picker-col">
      <div class="picker-label" id="lblR">Right Fighter</div>
      <div style="font-size:9px;color:#c4982a;margin-bottom:4px"><span id="plR">fighter power</span> · <span id="cR">0 / 1 selected</span></div>
      <div class="picker-grid" id="gR"></div>
    </div>
  </div>

  <!-- Fight button -->
  <div style="text-align:center;margin:10px 0">
    <button class="fight-btn" id="fBtn" onclick="startBattle()" disabled>⚔ Pick Fighters First</button>
    <div id="movePicker" style="margin-top:10px"></div>
  <div class="card" style="margin-top:10px"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px"><div class="sl" style="margin-bottom:0">⚔️ Recent Battles</div></div><div id="battleHistoryList"><div class="es">No battles yet! ⚔</div></div></div>
  </div>

  <!-- Upset flash -->
  <div class="upset-flash" id="uFlash">⚡ UPSET! ⚡</div>

  </div><!-- end panel-battle -->

  <div class="panel" id="panel-quests">
    <button onclick="startDungeon()" style="width:100%;padding:14px;background:linear-gradient(135deg,#7c3aed,#a855f7,#ec4899);border:none;border-radius:16px;font-size:15px;font-weight:900;color:white;cursor:pointer;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;box-shadow:0 6px 20px rgba(168,85,247,0.45);transition:all .2s">🏰 Dungeon Quest — Pick Your Fighters!</button>
    <div class="card"><div class="sl">Quests</div><div id="qlist"></div></div>
    <div class="card"><div class="sl">Events</div><div id="sevts"></div></div>
  </div><!-- end panels -->
  </div><!-- end app -->


<div class="dq-overlay" id="dqOverlay">
  <div class="dq-bg" id="dqBg">
    <div class="dq-sun"></div>
    <div class="dq-stars" id="dqStars"></div>
    <svg class="dq-mountains" viewBox="0 0 400 70" preserveAspectRatio="none" style="position:absolute;bottom:44%;left:0;right:0;height:70px;width:100%">
      <polygon points="0,70 60,20 110,50 170,8 230,45 290,15 350,40 400,22 400,70" fill="#2d5a1e" opacity="0.6"/>
      <polygon points="0,70 40,35 90,55 150,18 210,50 270,22 330,45 400,30 400,70" fill="#3a7028" opacity="0.7"/>
    </svg>
    <div class="dq-trees" id="dqTrees" style="gap:0"></div>
    <div class="dq-fence" id="dqFence">
      <div class="dq-fence-rail"></div>
      <div class="dq-fence-rail2"></div>
    </div>
    <div class="dq-ground-detail"></div>
    <div class="dq-path"></div>
    <div class="dq-divider"></div>
    <div class="dq-field">
      <div class="dq-team" id="dqTeamHeroes"></div>
      <div class="dq-team" id="dqTeamEnemies"></div>
    </div>
    <div class="dq-result" id="dqResult">
      <div class="dq-result-card">
        <div style="font-size:52px;margin-bottom:8px" id="dqResEmoji">🏆</div>
        <div style="font-size:22px;font-weight:900;color:#FFD600;letter-spacing:2px;margin-bottom:6px" id="dqResTitle">Victory!</div>
        <div style="font-size:11px;color:#c4982a;margin-bottom:4px" id="dqResSub"></div>
        <div id="dqChestArea"></div><button class="dq-result-btn" id="dqChestBtn" onclick="openTreasureChests()">🎁 Open Treasure Chests!</button>
      </div>
    </div>
  </div>
  <div class="dq-hud">
    <div class="dq-floor-lbl" id="dqFloorLabel">Floor 1</div>
    <div class="dq-hud-row" id="dqHeroes"></div>
    <div class="dq-log" id="dqLog"></div>
    <button class="dq-flee-btn" id="dqCloseBtn" onclick="closeDQ()">🏃 Flee</button>
    </div>
  </div>

  <!-- Victory overlay -->
  <div class="victory-overlay" id="victoryOverlay">
    <div class="victory-card">
      <span class="victory-trophy" id="vTrophy">🏆</span>
        <div class="victory-title">Winner!</div>
      <div class="victory-name" id="vName">—</div>
      <div class="victory-sub" id="vSub">—</div>
      <div class="victory-upset" id="vUpset">🔮 Upset Victory!</div>
      <button class="victory-btn" onclick="document.getElementById('victoryOverlay').classList.remove('show')">Play Again</button>
    </div>
  </div>
<script>
