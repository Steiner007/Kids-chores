var dqState=null;
function startDungeon(){
  // Show monster picker modal before dungeon begins
  showDungeonPicker();
}

function showDungeonPicker(){
  const existing = document.getElementById('dqPickerModal');
  if(existing) existing.remove();

  const overlay = document.createElement('div');
  overlay.id = 'dqPickerModal';
  overlay.style.cssText = 'position:fixed;inset:0;z-index:8500;background:rgba(5,0,20,0.95);display:flex;align-items:center;justify-content:center;overflow-y:auto;padding:16px;box-sizing:border-box';

  const box = document.createElement('div');
  box.style.cssText = 'background:linear-gradient(145deg,#1a0030,#2d0858);border:2px solid rgba(255,214,0,0.4);border-radius:20px;padding:20px;width:100%;max-width:420px;';

  // Title
  const title = document.createElement('div');
  title.style.cssText = 'font-size:18px;font-weight:900;color:#FFD600;text-align:center;margin-bottom:4px;letter-spacing:2px;text-transform:uppercase';
  title.textContent = '🏰 Dungeon Quest';
  box.appendChild(title);

  const sub = document.createElement('div');
  sub.style.cssText = 'font-size:11px;color:#c4982a;text-align:center;margin-bottom:16px';
  const dlvl2=S.dungeonLevel||0;
  if(dlvl2===0){
    sub.textContent='Each kid picks one monster to send into battle';
    sub.style.color='#c4982a';
  } else {
    sub.textContent='Run '+dlvl2+' beaten! Now entering Run '+(dlvl2+1)+' — '+Math.round((1+dlvl2*0.35)*100)+'% harder! Reward: '+(150+dlvl2*50)+' pts';
    sub.style.color='#FF5252';
  }
  box.appendChild(sub);

  // Per-kid picker
  const picks = {}; // kidIdx → monster object

  S.kids.forEach((kid, ki) => {
    const mons = getKidMons(ki);

    const kidSection = document.createElement('div');
    kidSection.style.cssText = 'margin-bottom:14px;background:rgba(255,255,255,0.04);border-radius:12px;padding:10px;border:1px solid rgba(255,214,0,0.15)';

    const kidLabel = document.createElement('div');
    kidLabel.style.cssText = 'font-size:12px;font-weight:800;color:white;margin-bottom:8px;display:flex;align-items:center;gap:6px';
    kidLabel.innerHTML = `<span style="background:linear-gradient(135deg,#7c3aed,#ec4899);padding:2px 10px;border-radius:10px">${kid.name}</span>` +
      (mons.length ? `<span style="color:#c4982a;font-size:10px">${mons.length} monsters</span>` : `<span style="color:#ff6b6b;font-size:10px">No monsters — will use a starter!</span>`);
    kidSection.appendChild(kidLabel);

    if(!mons.length){
      // Auto-pick a starter
      picks[ki] = MONSTERS[ki % MONSTERS.length];
      const starterEl = document.createElement('div');
      starterEl.style.cssText = 'font-size:10px;color:#888;text-align:center;padding:8px';
      starterEl.textContent = '→ ' + picks[ki].name + ' ⚡' + picks[ki].power;
      kidSection.appendChild(starterEl);
    } else {
      // Default pick = strongest
      picks[ki] = mons[0];

      const grid = document.createElement('div');
      grid.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;max-height:160px;overflow-y:auto';

      mons.forEach(m => {
        const rawSvg = m.svg || (MONSTERS.find(a=>a.id===m.id)||{}).svg || '';
        const svg = resizeSvg(rawSvg, 40, 40);
        const card = document.createElement('div');
        card.className = 'dq-pick-card' + (m === mons[0] ? ' selected' : '');
        card.dataset.kidIdx = ki;
        card.dataset.monId = m.id;
        card.innerHTML = svg +
          `<div style="font-size:8px;font-weight:700;color:#FFD600;margin-top:1px;line-height:1.1;text-align:center;max-width:50px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${m.name}</div>` +
          `<div style="font-size:8px;color:#FF8C00">⚡${m.power}</div>`;
        card.onclick = () => {
          // Deselect others for this kid
          grid.querySelectorAll('.dq-pick-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          picks[ki] = m;
        };
        grid.appendChild(card);
      });

      kidSection.appendChild(grid);
    }

    box.appendChild(kidSection);
  });

  // Buttons
  const btnRow = document.createElement('div');
  btnRow.style.cssText = 'display:flex;gap:8px;margin-top:4px';

  const cancelBtn = document.createElement('button');
  cancelBtn.textContent = 'Cancel';
  cancelBtn.style.cssText = 'flex:1;padding:11px;background:transparent;border:1px solid rgba(255,255,255,0.2);border-radius:12px;color:#c4982a;font-weight:700;font-size:13px;cursor:pointer';
  cancelBtn.onclick = () => overlay.remove();

  const goBtn = document.createElement('button');
  goBtn.textContent = '⚔ Enter Dungeon!';
  goBtn.style.cssText = 'flex:2;padding:11px;background:linear-gradient(135deg,#7c3aed,#ec4899);border:none;border-radius:12px;color:white;font-weight:900;font-size:14px;cursor:pointer;letter-spacing:1px;box-shadow:0 4px 16px rgba(124,58,237,0.5)';
  goBtn.onclick = () => {
    overlay.remove();
    launchDungeon(picks);
  };

  btnRow.appendChild(cancelBtn);
  btnRow.appendChild(goBtn);
  box.appendChild(btnRow);

  overlay.appendChild(box);
  overlay.addEventListener('click', e => { if(e.target===overlay) overlay.remove(); });
  document.body.appendChild(overlay);
}

// Seeded shuffle - same dlevel+floor always gives same rotation
function seededPick(arr, seed, count){
  const a=[...arr];
  // Fisher-Yates with seed
  let s=seed;
  for(let i=a.length-1;i>0;i--){
    s=(s*1664525+1013904223)&0xFFFFFFFF;
    const j=Math.abs(s)%(i+1);
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a.slice(0,count);
}

function makeEnemy(mon, dlevel){
  const hpBase = mon.power * 12 + 20;
  const hpMult = 1 + dlevel * 0.35;
  const hp = Math.round(hpBase * hpMult);
  return {
    name: mon.name,
    type: mon.type,
    power: Math.min(12, mon.power + Math.floor(dlevel * 0.5)),
    hp, maxHp: hp,
    svg: mon.svg || '',
    isBoss: false
  };
}

function scaleDungeonFloor(enemies, dlevel){
  // floor 0 of DUNGEON_FLOORS = first floor template
  // If dlevel=0 use original enemies, else pick from MONSTERS
  if(!dlevel) return JSON.parse(JSON.stringify(enemies));

  // Determine which power tier to draw from based on dlevel
  // Floor identity comes from the enemy's original power range
  const floorMinPow = Math.min(...enemies.map(e=>e.power));
  const tierShift = Math.min(4, Math.floor(dlevel * 0.7));
  const targetMinPow = floorMinPow + tierShift;
  const targetMaxPow = targetMinPow + 3;

  // Pick monsters from MONSTERS array in that power range
  const pool = MONSTERS.filter(m => m.power >= targetMinPow && m.power <= targetMaxPow);
  const fallback = MONSTERS.filter(m => m.power >= Math.max(1, targetMinPow-2));
  const usePool = pool.length >= 2 ? pool : fallback;

  // Seed based on dlevel + floor signature so same run = same monsters
  const seed = dlevel * 1000 + floorMinPow * 7;
  const picked = seededPick(usePool, seed, 2);
  let result = picked.map(m => makeEnemy(m, dlevel));

  // Every 2 levels add a third enemy
  if(dlevel >= 2 && dlevel % 2 === 0){
    const extra = seededPick(usePool, seed+999, 1)[0];
    if(extra){
      const extraEnemy = makeEnemy(extra, dlevel);
      extraEnemy.name = 'Elite ' + extra.name;
      extraEnemy.hp = Math.round(extraEnemy.hp * 0.75);
      extraEnemy.maxHp = extraEnemy.hp;
      result.push(extraEnemy);
    }
  }
  return result;
}

function makeBossEnemy(dlevel){
  // Boss: always picks from top-tier monsters, rotates each run
  const bossPool = MONSTERS.filter(m => m.power >= 7).sort((a,b)=>b.power-a.power);
  const seed = dlevel * 777 + 42;
  const picked = seededPick(bossPool, seed, 1)[0] || MONSTERS[0];
  const hpBase = picked.power * 20 + 100;
  const hpMult = 1 + dlevel * 0.4;
  const hp = Math.round(hpBase * hpMult);
  return [{
    name: (dlevel > 0 ? 'RUN '+dlevel+' BOSS: ' : 'BOSS: ') + picked.name,
    type: picked.type,
    power: Math.min(14, picked.power + Math.floor(dlevel * 0.6)),
    hp, maxHp: hp,
    svg: picked.svg || '',
    isBoss: true
  }];
}
function romanize(n){
  const v=[10,9,5,4,1],s=['X','IX','V','IV','I'];let r='';
  v.forEach((val,i)=>{while(n>=val){r+=s[i];n-=val;}});return r;
}
function launchDungeon(picks){
  dqState = {
    floor: 0,
    heroes: S.kids.map((k, i) => {
      const mon = picks[i] || MONSTERS[i % MONSTERS.length];
      return {
        name: k.name,
        mon: mon,
        hp: mon.power * 8 + 20,
        maxHp: mon.power * 8 + 20,
        dead: false
      };
    }),
    dungeonLevel: S.dungeonLevel||0,
    enemies: (S.dungeonLevel||0)===0
      ? JSON.parse(JSON.stringify(DUNGEON_FLOORS[0].enemies))
      : scaleDungeonFloor(DUNGEON_FLOORS[0].enemies, S.dungeonLevel||0),
    done: false, won: false, reward: 0,
  };
  document.getElementById('dqOverlay').classList.add('show');
  document.getElementById('dqResult').classList.remove('show');
  document.getElementById('dqCloseBtn').textContent = '🏃 Flee Dungeon';
  const dlvl=S.dungeonLevel||0;
  const entryMsg=dlvl===0?'The party enters the dungeon...':('Run '+dlvl+' cleared! Now on Run '+(dlvl)+' — enemies are '+Math.round((1+(dlvl-1)*0.35)*100)+'% stronger!');
  dqLog(entryMsg, dlvl===0?'#FFD600':'#FF5252');
  renderDQ();
  sfx('dq-enter');
  setTimeout(dqAutoRound, 1200);
}

function closeDQ(){
  // If won and chests not claimed yet - just close (flee)
  if(dqState?.won){
    // Give base reward anyway if fleeing after win
    if(dqState.reward){
      const each=Math.floor(dqState.reward/3);
      S.kids.forEach(k=>k.pts+=each);
      rKids();
    }
  }
  chestsOpened=0;
  document.getElementById('dqOverlay').classList.remove('show');
  dqState=null;
}

function dqLog(msg,color){
  const log=document.getElementById('dqLog');
  const d=document.createElement('div');
  d.style.color=color||'rgba(255,255,255,0.75)';
  d.textContent=msg;
  log.insertBefore(d,log.firstChild);
  if(log.children.length>40)log.removeChild(log.lastChild);
}

function renderDQ(){
  if(!dqState)return;
  const floor=DUNGEON_FLOORS[dqState.floor];
  document.getElementById('dqFloorLabel').textContent=floor.label+' ('+( dqState.floor+1)+'/'+DUNGEON_FLOORS.length+')';
  document.getElementById('dqHeroes').innerHTML=dqState.heroes.map(h=>{
    const pct=Math.max(0,h.hp/h.maxHp*100);
    return '<div class="dq-hud-hero'+(h.dead?' dead':'')+'"><div class="dq-hud-name">'+(h.dead?'KO - ':'')+h.name+'</div><div class="dq-hud-mon">'+h.mon.name+'</div><div class="dq-hud-hp-wrap"><div class="dq-hud-hp '+(pct<30?'lo':'hi')+'" style="width:'+pct+'%"></div></div><div class="dq-hud-hpnum">'+Math.max(0,Math.round(h.hp))+'/'+h.maxHp+' HP</div></div>';
  }).join('');
  const heroBox=document.getElementById('dqTeamHeroes');
  const enemyBox=document.getElementById('dqTeamEnemies');
  if(!heroBox||!enemyBox)return;
  dqState.heroes.forEach((h,i)=>{
    const pct=Math.max(0,h.hp/h.maxHp*100);
    let el=document.getElementById('dqunit-hero-'+i);
    if(!el){
      el=document.createElement('div');
      el.className='dq-unit hero-unit idle';
      el.id='dqunit-hero-'+i;
      el.innerHTML='<div class="dq-fhp-bar-wrap"><div class="dq-fhp-bar '+(pct<30?'lo':'hi')+'" id="dqhpb-hero-'+i+'" style="width:'+pct+'%"></div></div>'
        +resizeSvg(h.mon.svg||(MONSTERS.find(a=>a.id===h.mon.id)||{}).svg||'',58,58)
        +'<div class="dq-fname">'+h.name+'</div>';
      heroBox.appendChild(el);
    } else {
      const bar=document.getElementById('dqhpb-hero-'+i);
      if(bar){bar.style.width=pct+'%';bar.className='dq-fhp-bar '+(pct<30?'lo':'hi');}
      if(h.dead)el.classList.add('dead-unit');
    }
  });
  dqState.enemies.forEach((e,i)=>{
    const pct=Math.max(0,e.hp/e.maxHp*100);
    let el=document.getElementById('dqunit-enemy-'+i);
    if(!el && e.hp>0){
      el=document.createElement('div');
      el.className='dq-unit enemy-unit idle';
      el.id='dqunit-enemy-'+i;
      const sz=e.isBoss?74:54;
      el.innerHTML='<div class="dq-fhp-bar-wrap"><div class="dq-fhp-bar '+(pct<30?'lo':'hi')+'" id="dqhpb-enemy-'+i+'" style="width:'+pct+'%"></div></div>'
        +resizeSvg(e.svg||'',sz,sz)
        +'<div class="dq-fname">'+(e.isBoss?'BOSS: ':'')+e.name+'</div>';
      enemyBox.appendChild(el);
    } else if(el){
      const bar=document.getElementById('dqhpb-enemy-'+i);
      if(bar){bar.style.width=pct+'%';bar.className='dq-fhp-bar '+(pct<30?'lo':'hi');}
      if(e.hp<=0)el.classList.add('dead-unit');
    }
  });
}

function dqSpawnEffect(unitEl,dmg,isHeal){
  if(!unitEl)return;
  const bg=document.getElementById('dqBg');
  if(!bg)return;
  const r1=unitEl.getBoundingClientRect(), r2=bg.getBoundingClientRect();
  const x=r1.left-r2.left+r1.width/2, y=r1.top-r2.top;
  const hit=document.createElement('div');
  hit.className='dq-hit';
  hit.style.cssText='left:'+x+'px;top:'+y+'px;transform:translateX(-50%);position:absolute;';
  hit.textContent=isHeal?'💚':'💥';
  bg.appendChild(hit);
  const num=document.createElement('div');
  num.className='dq-hit-num';
  num.style.cssText='left:'+(x+14)+'px;top:'+(y-4)+'px;position:absolute;color:'+(isHeal?'#69F0AE':'#FF1744');
  num.textContent=(isHeal?'+':'-')+dmg;
  bg.appendChild(num);
  setTimeout(()=>{hit.remove();num.remove();},900);
}



async function dqAutoRound(){
  if(!dqState||dqState.done)return;

  // Heroes attack
  for(let hi=0;hi<dqState.heroes.length;hi++){
    const h=dqState.heroes[hi];
    if(h.dead)continue;
    const live=dqState.enemies.map((e,i)=>({e,i})).filter(({e})=>e.hp>0);
    if(!live.length)break;
    const {e:target,i:ei}=live[Math.floor(Math.random()*live.length)];
    const attacks=getAttacks(h.mon.type);
    const atk=attacks.reduce((best,a)=>a.dmgMul>best.dmgMul?a:best,attacks[0]);
    const dmg=Math.round((h.mon.power*3+5)*atk.dmgMul*(0.8+Math.random()*0.4));
    const hEl=document.getElementById('dqunit-hero-'+hi);
    if(hEl){hEl.classList.remove('idle','atk-right','atk-left');void hEl.offsetWidth;hEl.classList.add('atk-right');}
    await dqSleep(200);
    target.hp=Math.max(0,target.hp-dmg);
    dqSpawnEffect(document.getElementById('dqunit-enemy-'+ei),dmg,false);
    const eEl=document.getElementById('dqunit-enemy-'+ei);
    if(eEl){eEl.classList.add('hurting');setTimeout(()=>eEl.classList.remove('hurting'),350);}
    sfx('dq-hit');
    dqLog(h.name+String.fromCharCode(39)+'s '+h.mon.name+' '+atk.emoji+' '+atk.n+' hits '+target.name+' -'+dmg,'#FFD600');
    if(target.hp<=0){
      sfx('dq-ko');
      dqLog(target.name+' defeated! '+String.fromCharCode(55357,56485),'#FF7043');
      if(eEl)setTimeout(()=>eEl.classList.add('dead-unit'),200);
    }
    await dqSleep(150);
    if(hEl){hEl.classList.remove('atk-right','atk-left');hEl.classList.add('idle');}
    renderDQ();
    await dqSleep(350);
  }

  if(dqState.enemies.every(e=>e.hp<=0)){await dqNextFloor();return;}

  await dqSleep(200);
  for(let ei=0;ei<dqState.enemies.length;ei++){
    const e=dqState.enemies[ei];
    if(e.hp<=0)continue;
    const alive=dqState.heroes.map((h,i)=>({h,i})).filter(({h})=>!h.dead);
    if(!alive.length)break;
    const {h:target,i:ti}=alive[Math.floor(Math.random()*alive.length)];
    const dmg=Math.round((e.power*2+3)*(0.8+Math.random()*0.4));
    const eEl2=document.getElementById('dqunit-enemy-'+ei);
    if(eEl2){eEl2.classList.remove('idle','atk-right','atk-left');void eEl2.offsetWidth;eEl2.classList.add('atk-left');}
    await dqSleep(200);
    target.hp=Math.max(0,target.hp-dmg);
    dqSpawnEffect(document.getElementById('dqunit-hero-'+ti),dmg,false);
    const hEl2=document.getElementById('dqunit-hero-'+ti);
    if(hEl2){hEl2.classList.add('hurting');setTimeout(()=>hEl2.classList.remove('hurting'),350);}
    sfx('dq-hit');
    dqLog(e.name+' attacks '+target.name+' -'+dmg,'#FF7043');
    if(target.hp<=0){
      target.dead=true;
      sfx('dq-ko');
      dqLog(target.name+' KO\'d!','#E53935');
      if(hEl2)setTimeout(()=>hEl2.classList.add('dead-unit'),200);
    }
    await dqSleep(150);
    if(eEl2){eEl2.classList.remove('atk-right','atk-left');eEl2.classList.add('idle');}
    renderDQ();
    await dqSleep(350);
  }

  const alive=dqState.heroes.filter(h=>!h.dead);
  if(alive.length>1){
    const lowest=alive.sort((a,b)=>a.hp-b.hp)[0];
    if(lowest.hp<lowest.maxHp*0.5){
      const healer=alive.find(h=>h!==lowest);
      if(healer){
        const amt=Math.round(lowest.maxHp*0.2);
        lowest.hp=Math.min(lowest.maxHp,lowest.hp+amt);
        const ti=dqState.heroes.indexOf(lowest);
        dqSpawnEffect(document.getElementById('dqunit-hero-'+ti),amt,true);
        sfx('dq-heal');
        dqLog(healer.name+' heals '+lowest.name+' +'+amt+' HP','#69F0AE');
        renderDQ();
        await dqSleep(400);
      }
    }
  }

  if(dqState.heroes.every(h=>h.dead)){dqLoss();return;}
  if(!dqState.done)setTimeout(dqAutoRound,800);
}

function dqSleep(ms){return new Promise(r=>setTimeout(r,ms));}

async function dqNextFloor(){
  dqState.floor++;
  ['dqTeamHeroes','dqTeamEnemies'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML='';})
  if(dqState.floor>=DUNGEON_FLOORS.length){dqWin();return;}
  const isBossFloor = dqState.floor >= DUNGEON_FLOORS.length - 1;
  const dlvl = dqState.dungeonLevel || 0;
  if(isBossFloor && dlvl > 0){
    dqState.enemies = makeBossEnemy(dlvl);
  } else {
    dqState.enemies = scaleDungeonFloor(DUNGEON_FLOORS[dqState.floor].enemies, dlvl);
  }
  if(isBossFloor)sfx('dq-boss');
  sfx('dq-floor');
  dqLog('━━ Entering '+DUNGEON_FLOORS[dqState.floor].label+' ━━','#FFD600');
  renderDQ();
  await dqSleep(800);
  dqAutoRound();
}

function dqWin(){
  S.dungeonLevel=(S.dungeonLevel||0)+1;
  const reward=150+(S.dungeonLevel-1)*50;
  dqState.done=true;dqState.won=true;dqState.reward=reward;
  document.getElementById('dqResult').classList.add('show');
  sfx('dq-win');
  document.getElementById('dqResEmoji').textContent='🏆';
  document.getElementById('dqResTitle').textContent='DUNGEON CLEARED! (Run '+S.dungeonLevel+')';
  document.getElementById('dqResSub').textContent='Each kid earns '+Math.floor(reward/3)+' pts bonus! Open your chests!';
  // Clear any old chest content
  const ca=document.getElementById('dqChestArea');
  if(ca)ca.innerHTML='';
  const cb2=document.getElementById('dqChestBtn');
  if(cb2){cb2.style.display='';cb2.textContent='🎁 Open Treasure Chests!';}
  chestsOpened=0;
}

function dqLoss(){
  dqState.done=true;
  document.getElementById('dqResult').classList.add('show');
  sfx('dq-loss');
  document.getElementById('dqResEmoji').textContent='💀';
  document.getElementById('dqResTitle').textContent='PARTY WIPED!';
  document.getElementById('dqResSub').textContent='Better luck next time...';
}
</script>
</body>
</html>
