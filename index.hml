  {id:"bigfoot2",name:"Stompy McStompface",type:"blob",power:4,anim:"wo",svg:'<svg viewBox="0 0 80 80"><ellipse cx="40" cy="52" rx="30" ry="20" fill="#FFCCBC"/><ellipse cx="40" cy="50" rx="28" ry="18" fill="#FFAB91"/><circle cx="24" cy="40" r="12" fill="#FFCCBC"/><circle cx="56" cy="40" r="12" fill="#FFCCBC"/><ellipse cx="18" cy="60" rx="12" ry="8" fill="#FF8A65"/><ellipse cx="30" cy="65" rx="9" ry="7" fill="#FF8A65"/><ellipse cx="40" cy="67" rx="8" ry="6" fill="#FF8A65"/><ellipse cx="50" cy="65" rx="9" ry="7" fill="#FF8A65"/><ellipse cx="62" cy="60" rx="12" ry="8" fill="#FF8A65"/><circle cx="18" cy="60" r="4" fill="#FFCCBC"/><circle cx="30" cy="65" r="4" fill="#FFCCBC"/><circle cx="40" cy="67" r="4" fill="#FFCCBC"/><circle cx="50" cy="65" r="4" fill="#FFCCBC"/><circle cx="62" cy="60" r="4" fill="#FFCCBC"/><ellipse cx="28" cy="38" rx="7" ry="6" fill="white"/><ellipse cx="52" cy="38" rx="7" ry="6" fill="white"/><circle cx="28" cy="38" r="4" fill="#5D4037"/><circle cx="52" cy="38" r="4" fill="#5D4037"/><circle cx="27" cy="37" r="1.5" fill="white"/><circle cx="51" cy="37" r="1.5" fill="white"/><path d="M30 46 Q40 52 50 46" fill="none" stroke="#BF360C" stroke-width="2" stroke-linecap="round"/><\/svg>'},
  {id:"bonehead",name:"Boney Bob",type:"shadow",power:6,anim:"ap",svg:'<svg viewBox="0 0 80 80"><ellipse cx="40" cy="28" rx="24" ry="22" fill="#FAFAFA"/><ellipse cx="40" cy="26" rx="22" ry="20" fill="#F5F5F5"/><circle cx="20" cy="24" r="10" fill="#FAFAFA"/><circle cx="60" cy="24" r="10" fill="#FAFAFA"/><ellipse cx="30" cy="32" rx="9" ry="10" fill="black"/><ellipse cx="50" cy="32" rx="9" ry="10" fill="black"/><ellipse cx="30" cy="32" rx="6" ry="7" fill="#1a1a1a"/><ellipse cx="50" cy="32" rx="6" ry="7" fill="#1a1a1a"/><circle cx="28" cy="30" r="2" fill="#546E7A"/><circle cx="48" cy="30" r="2" fill="#546E7A"/><rect x="28" y="46" width="24" height="8" rx="2" fill="#FAFAFA"/><path d="M28 46 L28 54 M32 46 L32 54 M36 46 L36 54 M40 46 L40 54 M44 46 L44 54 M48 46 L48 54 M52 46 L52 54" stroke="#E0E0E0" stroke-width="1.5"/><path d="M28 50 L52 50" stroke="#E0E0E0" stroke-width="1.5"/><ellipse cx="40" cy="42" rx="8" ry="5" fill="#FAFAFA"/><circle cx="36" cy="40" r="2.5" fill="#F5F5F5"/><circle cx="44" cy="40" r="2.5" fill="#F5F5F5"/><circle cx="36" cy="40" r="1.5" fill="#BDBDBD"/><circle cx="44" cy="40" r="1.5" fill="#BDBDBD"/><\/svg>'},
  {id:"handsy",name:"The Grabber",type:"wind",power:5,anim:"af",svg:'<svg viewBox="0 0 80 80"><ellipse cx="40" cy="56" rx="26" ry="18" fill="#FFCCBC"/><ellipse cx="40" cy="54" rx="24" ry="16" fill="#FFAB91"/><rect x="28" y="20" width="8" height="30" rx="4" fill="#FFCCBC"/><rect x="38" y="16" width="8" height="32" rx="4" fill="#FFCCBC"/><rect x="48" y="20" width="8" height="30" rx="4" fill="#FFCCBC"/><rect x="18" y="26" width="8" height="28" rx="4" fill="#FFCCBC"/><ellipse cx="32" cy="50" rx="6" ry="7" fill="white"/><ellipse cx="48" cy="50" rx="6" ry="7" fill="white"/><circle cx="32" cy="50" r="4" fill="#E64A19"/><circle cx="48" cy="50" r="4" fill="#E64A19"/><circle cx="31" cy="49" r="1.5" fill="white"/><circle cx="47" cy="49" r="1.5" fill="white"/><path d="M30 58 Q40 64 50 58" fill="none" stroke="#BF360C" stroke-width="2" stroke-linecap="round"/><rect x="28" y="48" width="6" height="4" rx="1" fill="#FFAB91"/><rect x="46" y="48" width="6" height="4" rx="1" fill="#FFAB91"/><\/svg>'},
  {id:"nosejob",name:"Sniffy McSniff",type:"water",power:2,anim:"wo",svg:'<svg viewBox="0 0 80 80"><ellipse cx="40" cy="44" rx="26" ry="28" fill="#FFCCBC"/><ellipse cx="40" cy="42" rx="24" ry="26" fill="#FFAB91"/><ellipse cx="40" cy="34" rx="18" ry="20" fill="#FFCCBC"/><ellipse cx="28" cy="54" rx="10" ry="12" fill="#FFAB91"/><ellipse cx="52" cy="54" rx="10" ry="12" fill="#FFAB91"/><circle cx="28" cy="52" r="7" fill="#FF7043" opacity="0.6"/><circle cx="52" cy="52" r="7" fill="#FF7043" opacity="0.6"/><ellipse cx="34" cy="34" rx="6" ry="6.5" fill="white"/><ellipse cx="46" cy="34" rx="6" ry="6.5" fill="white"/><circle cx="34" cy="34" r="4" fill="#5D4037"/><circle cx="46" cy="34" r="4" fill="#5D4037"/><circle cx="33" cy="33" r="1.5" fill="white"/><circle cx="45" cy="33" r="1.5" fill="white"/><path d="M32 44 Q40 50 48 44" fill="none" stroke="#BF360C" stroke-width="2" stroke-linecap="round"/><ellipse cx="28" cy="60" rx="5" ry="3" fill="#E64A19" opacity="0.5"/><ellipse cx="52" cy="60" rx="5" ry="3" fill="#E64A19" opacity="0.5"/><path d="M34 46 L32 52 M40 48 L40 54 M46 46 L48 52" stroke="#FFAB91" stroke-width="1.5" stroke-linecap="round"/><\/svg>'},
  {id:"teethter",name:"Chomp Chomp",type:"knight",power:6,anim:"ab",svg:'<svg viewBox="0 0 80 80"><path d="M8 44 Q10 30 40 28 Q70 30 72 44 Q66 62 40 64 Q14 62 8 44Z" fill="#FAFAFA"/><path d="M8 44 Q10 34 40 32 Q70 34 72 44 Q66 58 40 60 Q14 58 8 44Z" fill="#F5F5F5"/><path d="M8 44 Q12 36 20 38 L20 54 Q14 52 8 44Z" fill="#FFCCBC"/><path d="M72 44 Q68 36 60 38 L60 54 Q66 52 72 44Z" fill="#FFCCBC"/><rect x="18" y="38" width="8" height="16" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/><rect x="28" y="36" width="8" height="20" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/><rect x="38" y="36" width="8" height="20" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/><rect x="48" y="36" width="8" height="20" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/><rect x="58" y="38" width="8" height="16" rx="2" fill="white" stroke="#E0E0E0" stroke-width="1"/><ellipse cx="28" cy="40" rx="5" ry="5.5" fill="white"/><ellipse cx="52" cy="40" rx="5" ry="5.5" fill="white"/><circle cx="28" cy="40" r="3.5" fill="#1565C0"/><circle cx="52" cy="40" r="3.5" fill="#1565C0"/><circle cx="27" cy="39" r="1.5" fill="white"/><circle cx="51" cy="39" r="1.5" fill="white"/><\/svg>'}
];

const ATTACK_MOVES={
  fire:   [{n:'Fireball',dmgMul:1.2,emoji:'🔥'},{n:'Flame Breath',dmgMul:1.5,emoji:'🌋'},{n:'Ember Burst',dmgMul:0.9,emoji:'✨'}],
  water:  [{n:'Water Gun',dmgMul:1.1,emoji:'💧'},{n:'Tidal Wave',dmgMul:1.4,emoji:'🌊'},{n:'Bubble Blast',dmgMul:0.8,emoji:'🫧'}],
  thunder:[{n:'Thunderbolt',dmgMul:1.3,emoji:'⚡'},{n:'Lightning Storm',dmgMul:1.6,emoji:'🌩️'},{n:'Spark',dmgMul:0.7,emoji:'✨'}],
  shadow: [{n:'Dark Pulse',dmgMul:1.2,emoji:'🌑'},{n:'Shadow Ball',dmgMul:1.4,emoji:'💜'},{n:'Void Strike',dmgMul:1.0,emoji:'🕳️'}],
  wind:   [{n:'Gust',dmgMul:1.0,emoji:'💨'},{n:'Tornado',dmgMul:1.5,emoji:'🌪️'},{n:'Air Slash',dmgMul:1.1,emoji:'🌬️'}],
  blob:   [{n:'Splat',dmgMul:1.1,emoji:'💦'},{n:'Slime Bomb',dmgMul:1.3,emoji:'🟢'},{n:'Gooey Grab',dmgMul:0.9,emoji:'🫗'}],
  knight: [{n:'Sword Slash',dmgMul:1.2,emoji:'⚔️'},{n:'Shield Bash',dmgMul:0.8,emoji:'🛡️'},{n:'Lance Charge',dmgMul:1.5,emoji:'🗡️'}],
  cube:   [{n:'Wobble Smash',dmgMul:1.0,emoji:'📦'},{n:'Cube Crush',dmgMul:1.3,emoji:'💎'},{n:'Corner Jab',dmgMul:0.9,emoji:'📐'}],
};
function getAttacks(type){return ATTACK_MOVES[type]||ATTACK_MOVES.blob;}

const SOUNDS=['WHAM!','POW!','BONK!','SMACK!','ZAPP!','OOOF!','BOING!','CRASH!'];
const HITFX=['💥','⚡','✨','💫','🔥','❄️','💨','🌟'];

var mode='1v1', selL=[], selR=[], fighting=false;
var mxL=0, mxR=0, cL=0, cR=0;
const MAXTEAM=3;

// Particle system on the small canvas overlay — lazy-init so it doesn't crash before DOM ready
var pc = null, pctx = null;
var particles = [];
function initCanvas(){
  if(pctx) return;
  pc = document.getElementById('pCanvas');
  if(pc) pctx = pc.getContext('2d');
}

function resizeParticleCanvas(){
  initCanvas(); if(!pc) return;
  const col = document.getElementById('colosseum');
  pc.width = col.offsetWidth;
  pc.height = col.offsetHeight;
}

function pLoop(){
  initCanvas(); if(!pctx)return;
  pctx.clearRect(0,0,pc.width,pc.height);
  try{
  particles = particles.filter(p=>p.life>0);
  particles.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; if(p.gravity)p.vy+=p.gravity; p.life--;
    const a = Math.max(0,p.life/p.maxLife);
    pctx.save(); pctx.globalAlpha=a;
    if(p.type==='fire'||p.type==='water'||p.type==='shadow'){
      pctx.fillStyle=p.color; pctx.beginPath(); pctx.arc(p.x,p.y,p.r,0,Math.PI*2); pctx.fill();
    } else if(p.type==='thunder'){
      pctx.strokeStyle=p.color; pctx.lineWidth=p.r;
      pctx.beginPath(); pctx.moveTo(p.x,p.y); pctx.lineTo(p.x+p.dx,p.y+p.dy); pctx.stroke();
    } else if(p.type==='wind'){
      pctx.strokeStyle=p.color; pctx.lineWidth=1.5; pctx.beginPath();
      pctx.moveTo(p.x,p.y); pctx.bezierCurveTo(p.x+p.cx,p.y-p.cy,p.x+p.cx*2,p.y+p.cy,p.x+p.dx,p.y); pctx.stroke();
    }
    pctx.restore();
  });
  requestAnimationFrame(pLoop);
  }catch(e){requestAnimationFrame(pLoop);}
}

function spawnParticles(type, fx, fy, tx, ty){
  initCanvas(); if(!pc)return;
  const dir = tx>fx?1:-1;
  const W = pc.width, H = pc.height;
  for(let i=0;i<14;i++){
    const t=i/14;
    const cx=fx+(tx-fx)*t+(Math.random()-0.5)*16;
    const cy=fy+(ty-fy)*t+Math.sin(t*Math.PI)*-20+(Math.random()-0.5)*12;
    if(type==='fire'){
      particles.push({type:'fire',x:cx,y:cy,vx:dir*0.8+(Math.random()-0.5),vy:-1.5-Math.random()*2,r:3+Math.random()*5,life:22,maxLife:22,gravity:0.12,color:['#FF6D00','#FF9800','#FFD600'][Math.floor(Math.random()*3)]});
    } else if(type==='water'){
      particles.push({type:'water',x:cx,y:cy,vx:dir*1.8+(Math.random()-0.5),vy:-0.8-Math.random()*1.5,r:2.5+Math.random()*3.5,life:20,maxLife:20,gravity:0.18,color:['#29B6F6','#4FC3F7','#B3E5FC'][Math.floor(Math.random()*3)]});
    } else if(type==='thunder'){
      particles.push({type:'thunder',x:fx+(tx-fx)*Math.random()+(Math.random()-0.5)*25,y:fy-50-Math.random()*40,vx:0,vy:0,dx:(Math.random()-0.5)*35,dy:20+Math.random()*25,r:1.5+Math.random()*2,life:8,maxLife:8,gravity:0,color:'#FFD600'});
    } else if(type==='shadow'){
      particles.push({type:'shadow',x:cx,y:cy,vx:dir*(Math.random()*2.5),vy:-Math.random()*2,r:5+Math.random()*8,life:20,maxLife:20,gravity:-0.04,color:['#9C27B0','#CE93D8','#E040FB'][Math.floor(Math.random()*3)]});
    } else if(type==='wind'){
      particles.push({type:'wind',x:fx+(tx-fx)*t,y:fy-30+Math.sin(t*Math.PI)*-18,dx:dir*24,cx:dir*10,cy:6+Math.random()*5,life:12,maxLife:12,color:'#80DEEA'});
    } else {
      particles.push({type:'fire',x:cx,y:cy,vx:(Math.random()-0.5)*3,vy:-2-Math.random()*2,r:3+Math.random()*4,life:18,maxLife:18,gravity:0.1,color:'#FF5722'});
    }
  }
}

// Build arches
function buildArches(){
  const a = document.getElementById('arches');
  let h=''; for(let i=0;i<10;i++) h+=`<div class="arch" style="height:${85+Math.sin(i)*15}px"><\/div>`;
  a.innerHTML=h;
}

// Render fighters into arena slots as real HTML SVG
function renderFighters(){
  ['L','R'].forEach(side=>{
    const slot = document.getElementById('slot-'+side);
    const arr = side==='L'?selL:selR;
    const ms = gm(arr, side);
    if(!ms.length){
      slot.innerHTML=`<div style="width:70px;height:80px;display:flex;align-items:center;justify-content:center;opacity:0.2;font-size:28px;color:#8B6914">?<\/div>`;
      return;
    }
    const sz = ms.length===1?80:ms.length===2?64:52;
    slot.innerHTML = ms.map((m,i)=>{const rawSvg=m.svg||(MONSTERS.find(a=>a.id===m.id)||{}).svg||'';const fSvg=resizeSvg(rawSvg,sz,sz);const fAnim=m.anim||(MONSTERS.find(a=>a.id===m.id)||{}).anim||'wo';return`
      <div class="fighter ${fAnim}" id="fighter-${side}-${i}" data-side="${side}" data-idx="${i}">
        ${fSvg}
        <div class="fighter-label">${m.name}<\/div>
        <div class="fighter-pwr">⚡${m.power}<\/div>
      <\/div>`;}).join('');
  });
}

function gm(arr,side){
  // Get monster objects - look in the selecting kid's collection first
  const kidIdx=side==='R'?battleKidR:battleKidL;
  const col=S.kids[kidIdx]?.col||[];
  return arr.map(id=>{
    // Find in kid's collection
    const fromCol=col.find(m=>m.id===id);
    if(fromCol)return fromCol;
    // Fallback to MONSTERS array
    return MONSTERS.find(m=>m.id===id);
  }).filter(Boolean);
}
// Strip baked-in width/height, apply correct size
function resizeSvg(svg,w,h){
  if(!svg||typeof svg!=='string')return '';
  let s=svg.replace(/(<svg[^>]*?)\s+width="[^"]*"/,'$1').replace(/(<svg[^>]*?)\s+height="[^"]*"/,'$1');
  if(w&&h)s=s.replace('viewBox="0 0 80 80"','viewBox="0 0 80 80" width="'+w+'" height="'+h+'"');
  return s;
}

function tp(arr,side){ return gm(arr,side||'L').reduce((s,m)=>s+m.power,0); }

function setMode(m,el){
  mode=m;
  document.querySelectorAll('.mode-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  selL=[];selR=[];
  ['L','R'].forEach(s=>{
    rfPicker(s);
    const lEl=document.getElementById('l'+s); if(lEl)lEl.textContent=m==='1v1'?(s==='L'?'Left Fighter':'Right Fighter'):(s==='L'?'Team 1 (up to 3)':'Team 2 (up to 3)');
    const plEl=document.getElementById('pl'+s); if(plEl)plEl.textContent=m==='1v1'?'fighter power':'team power';
  });
  updateUI(); chkReady();
}

function tog(side,id){
  const arr=side==='L'?selL:selR;
  const max=mode==='1v1'?1:MAXTEAM;
  const idx=arr.indexOf(id);
  if(idx>=0)arr.splice(idx,1);
  else{if(arr.length>=max)arr.shift(); arr.push(id);}
  rfPicker(side); updateUI(); chkReady();
}

function rfPicker(side){
  const arr=side==='L'?selL:selR;
  const max=mode==='1v1'?1:MAXTEAM;
  document.querySelectorAll('#g'+side+' .pc').forEach(el=>el.classList.remove('sel'));
  arr.forEach(id=>{const el=document.getElementById('pc'+side+id);if(el)el.classList.add('sel');});
  const cEl=document.getElementById('c'+side);if(cEl)cEl.textContent=arr.length+' / '+max+' selected';
}

// Per-monster HP tracking
var monHP = {}; // key: 'L_0', 'R_1' etc → {cur, max}

function buildHPBars(){
  ['L','R'].forEach(side=>{
    const ms = gm(side==='L'?selL:selR,side);
    const box = document.getElementById('hp-side-'+side);
    const label = side==='L'?'Team 1':'Team 2';
    if(!ms.length){
      box.innerHTML=`<div class="hp-team-label">${label}<\/div><div style="color:rgba(255,255,255,0.2);font-size:10px;font-family:sans-serif">No fighters<\/div>`;
      return;
    }
    let html = `<div class="hp-team-label">${label}<\/div>`;
    ms.forEach((m,i)=>{
      const key=side+'_'+i;
      const maxHp = m.power*10+20;
      monHP[key]={cur:maxHp,max:maxHp};
      html+=`<div class="hp-monster" id="hpm-${key}">
        <div class="hp-name" id="hpn-${key}">${m.name}<\/div>
        <div class="hp-wrap"><div class="hp-bar hi" id="hpb-${key}" style="width:100%"><\/div><\/div>
        <div class="hp-num" id="hpt-${key}">${maxHp} HP<\/div>
      <\/div>`;
    });
    box.innerHTML=html;
  });
}

function setMonHP(side, idx, cur, max){
  const key=side+'_'+idx;
  const pct=Math.max(0,Math.round(cur/max*100));
  const bar=document.getElementById('hpb-'+key);
  const num=document.getElementById('hpt-'+key);
  const nm=document.getElementById('hpn-'+key);
  if(bar){ bar.style.width=pct+'%'; bar.className='hp-bar '+(pct>60?'hi':pct>30?'md':'lo'); }
  if(num) num.textContent=Math.max(0,Math.round(cur))+' HP';
}

function setMonDead(side, idx){
  const key=side+'_'+idx;
  const bar=document.getElementById('hpb-'+key);
  const num=document.getElementById('hpt-'+key);
  const nm=document.getElementById('hpn-'+key);
  if(bar){ bar.className='hp-bar dead'; bar.style.width='0%'; }
  if(num){ num.textContent='💀 DEAD'; num.className='hp-num dead-txt'; }
  if(nm) nm.className='hp-name dead-label';
}

function updateUI(){
  const pL=tp(selL,'L'), pR=tp(selR,'R');
  const mL=gm(selL,'L'), mR=gm(selR,'R');
  const elPL=document.getElementById('plL'); if(elPL)elPL.textContent='⚡'+pL;
  const elPR=document.getElementById('plR'); if(elPR)elPR.textContent='⚡'+pR;
  mxL=pL*10+20; mxR=pR*10+20; cL=mxL; cR=mxR;
  buildHPBars();
  renderFighters();
}

function setHP(side,pct){
  // legacy stub - individual bars now handled by setMonHP
}

function chkReady(){
  const ok=selL.length>0&&selR.length>0;
  const btn=document.getElementById('fBtn');
  btn.disabled=!ok;
  btn.textContent=ok?'⚔ FIGHT!':'⚔ Pick Fighters First';
}

var battleKidL=0, battleKidR=1;
function getKidMons(kidIdx){
  const col=(S.kids[kidIdx]?.col)||[];
  // Deduplicate by id, keeping first occurrence
  const seen=new Set();
  const unique=[];
  for(const m of col){
    if(!seen.has(m.id)){seen.add(m.id);unique.push(m);}
  }
  // Sort by power desc
  unique.sort((a,b)=>b.power-a.power);
  return unique;
}
function setBattleKid(side,kidIdx){
  if(side==='L'){battleKidL=kidIdx;selL=[];}
  else{battleKidR=kidIdx;selR=[];}
  buildGrids();updateUI();chkReady();
}
function buildGrids(){
  ['L','R'].forEach(side=>{
    const kidIdx=side==='L'?battleKidL:battleKidR;
    const k=S.kids[kidIdx];
    const lbl=document.getElementById('lbl'+side);
    if(lbl)lbl.textContent=(k?.name||'Kid')+"'s Fighters";
    const hlbl=document.getElementById('l'+side);
    if(hlbl)hlbl.textContent=(k?.name||'Kid')+"'s Team";
    buildPickerGrid(side);
  });
}

function buildPickerGrid(side){
  const kidIdx=side==='L'?battleKidL:battleKidR;
  const mons=getKidMons(kidIdx);
  const grid=document.getElementById('g'+side);

  // Kid selector row
  const selRow=document.createElement('div');
  selRow.style.cssText='display:flex;gap:4px;margin-bottom:6px;flex-wrap:wrap';
  S.kids.forEach((kd,i)=>{
    const active=(side==='L'?battleKidL:battleKidR)===i;
    const btn=document.createElement('button');
    btn.textContent=kd.name+' ('+getKidMons(i).length+')';
    btn.style.cssText='padding:3px 8px;font-size:10px;font-weight:700;border-radius:6px;cursor:pointer;border:1px solid '+(active?'#FFD600':'rgba(255,214,0,0.2)')+';background:'+(active?'rgba(255,214,0,0.2)':'transparent')+';color:'+(active?'#FFD600':'#c4982a');
    btn.onclick=()=>setBattleKid(side,i);
    selRow.appendChild(btn);
  });

  grid.innerHTML='';
  grid.appendChild(selRow);

  if(!mons.length){
    const msg=document.createElement('div');
    msg.style.cssText='text-align:center;padding:20px;color:rgba(255,255,255,0.3);font-size:11px;';
    msg.innerHTML='No monsters yet!<br>Buy packs in the Shop 📦';
    grid.appendChild(msg);
    return;
  }

  mons.forEach(m=>{
    const card=document.createElement('div');
    card.className='pc';
    card.id='pc'+side+m.id;
    const aM=MONSTERS.find(a=>a.id===m.id);const pSvg=m.svg||aM?.svg||'';const svgSmall=resizeSvg(pSvg,38,38);
    card.innerHTML=svgSmall+'<div class="pc-name">'+m.name+'</div><div class="pc-pwr">⚡'+m.power+'</div>';
    card.onclick=()=>tog(side,m.id);
    grid.appendChild(card);
  });

  // Restore selection highlights
  (side==='L'?selL:selR).forEach(id=>{
    const el=document.getElementById('pc'+side+id);
    if(el)el.classList.add('sel');
  });
}
function addLog(icon,msg,cls=''){
  const log=document.getElementById('blog');
  const d=document.createElement('div'); d.className='le';
  d.innerHTML=`<span class="li">${icon}<\/span><span class="lm ${cls}">${msg}<\/span>`;
  log.insertBefore(d,log.firstChild);
  while(log.children.length>20)log.removeChild(log.lastChild);
}

function showHit(side,dmg,isCrit,isMiss,isUpset){
  const col=document.getElementById('colosseum');
  const slot=document.getElementById('slot-'+side);
  const rect=slot.getBoundingClientRect();
  const colRect=col.getBoundingClientRect();
  const el=document.createElement('div'); el.className='hit-fx';
  const text=isMiss?'MISS!':isUpset?'UPSET -'+dmg:isCrit?'CRIT -'+dmg:'-'+dmg;
  const color=isMiss?'rgba(200,200,200,0.6)':isUpset?'#E040FB':isCrit?'#FF1744':'#FF7043';
  el.textContent=text; el.style.color=color;
  el.style.left=(rect.left-colRect.left+Math.random()*30)+'px';
  el.style.top=(rect.top-colRect.top+40)+'px';
  document.getElementById('hit-layer').appendChild(el);
  setTimeout(()=>el.remove(),900);
}

function getFighterCenter(side,idx){
  const col=document.getElementById('colosseum');
  const f=document.getElementById(`fighter-${side}-${idx}`);
  if(!f)return{x:side==='L'?80:col.offsetWidth-80, y:col.offsetHeight-100};
  const r=f.getBoundingClientRect(), cr=col.getBoundingClientRect();
  return{x:r.left-cr.left+r.width/2, y:r.top-cr.top+r.height/2};
}

const sleep=ms=>new Promise(r=>setTimeout(r,ms));

function rollAtk(atkP,defP){
  const hit=Math.min(92,Math.max(8,38+atkP*5-defP*3));
  if(Math.random()*100>hit)return{hit:false,crit:false,upset:false,dmg:0};
  const crit=Math.random()*100<(5+Math.max(0,(atkP-defP)*2));
  const upset=atkP<=3&&defP>=7&&Math.random()*100<9;
  let dmg=atkP*(0.7+Math.random()*1.6)+Math.random()*5;
  if(crit)dmg*=2.2; if(upset)dmg*=3.5;
  return{hit:true,crit,upset,dmg:Math.round(dmg)};
}

// ── BATTLE SOUNDS ───────────────────────────────────────────────────
function sfxHit(power){
  // Thud + pitch based on power
  try{
    const a=ac();
    const noise=a.createOscillator(), g=a.createGain();
    noise.type='sawtooth';
    noise.frequency.setValueAtTime(60+power*18,a.currentTime);
    noise.frequency.exponentialRampToValueAtTime(20,a.currentTime+0.12);
    g.gain.setValueAtTime(0.3,a.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+0.15);
    noise.connect(g);g.connect(a.destination);
    noise.start();noise.stop(a.currentTime+0.18);
    // Click transient
    const c=a.createOscillator(),cg=a.createGain();
    c.type='square';c.frequency.value=200+power*30;
    cg.gain.setValueAtTime(0.15,a.currentTime);
    cg.gain.exponentialRampToValueAtTime(0.001,a.currentTime+0.06);
    c.connect(cg);cg.connect(a.destination);c.start();c.stop(a.currentTime+0.07);
  }catch(e){}
}
function sfxCrit(){
  try{
    const a=ac();
    [[220,0],[330,0.04],[500,0.08],[750,0.13]].forEach(([f,d])=>{
      const o=a.createOscillator(),g=a.createGain();
      o.type='square';o.frequency.value=f;
      g.gain.setValueAtTime(0.25,a.currentTime+d);
      g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+d+0.1);
      o.connect(g);g.connect(a.destination);
      o.start(a.currentTime+d);o.stop(a.currentTime+d+0.12);
    });
  }catch(e){}
}
function sfxMiss(){
  try{
    const a=ac(),o=a.createOscillator(),g=a.createGain();
    o.type='sine';o.frequency.setValueAtTime(300,a.currentTime);
    o.frequency.exponentialRampToValueAtTime(150,a.currentTime+0.1);
    g.gain.setValueAtTime(0.08,a.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+0.12);
    o.connect(g);g.connect(a.destination);o.start();o.stop(a.currentTime+0.14);
  }catch(e){}
}
function sfxKO(){
  try{
    const a=ac();
    [[100,0],[80,0.1],[60,0.22],[40,0.38]].forEach(([f,d])=>{
      const o=a.createOscillator(),g=a.createGain();
      o.type='sawtooth';o.frequency.value=f;
      g.gain.setValueAtTime(0.35,a.currentTime+d);
      g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+d+0.18);
      o.connect(g);g.connect(a.destination);
      o.start(a.currentTime+d);o.stop(a.currentTime+d+0.2);
    });
  }catch(e){}
}
function sfxVictory(){
  try{
    const a=ac();
    const melody=[523,659,784,1047,784,1047,1175];
    melody.forEach((f,i)=>{
      const o=a.createOscillator(),g=a.createGain();
      o.type='square';o.frequency.value=f;
      g.gain.setValueAtTime(0.18,a.currentTime+i*0.1);
      g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+i*0.1+0.12);
      o.connect(g);g.connect(a.destination);
      o.start(a.currentTime+i*0.1);o.stop(a.currentTime+i*0.1+0.15);
    });
  }catch(e){}
}
function sfxUpset(){
  try{
    const a=ac();
    [[800,0],[400,0.06],[1200,0.12],[600,0.2],[1600,0.28]].forEach(([f,d])=>{
      const o=a.createOscillator(),g=a.createGain();
      o.type='square';o.frequency.value=f;
      g.gain.setValueAtTime(0.2,a.currentTime+d);
      g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+d+0.09);
      o.connect(g);g.connect(a.destination);
      o.start(a.currentTime+d);o.stop(a.currentTime+d+0.11);
    });
  }catch(e){}
}
function sfxCharge(){
  // Play before lunge
  try{
    const a=ac(),o=a.createOscillator(),g=a.createGain();
    o.type='sawtooth';
    o.frequency.setValueAtTime(80,a.currentTime);
    o.frequency.exponentialRampToValueAtTime(280,a.currentTime+0.12);
    g.gain.setValueAtTime(0.12,a.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+0.14);
    o.connect(g);g.connect(a.destination);o.start();o.stop(a.currentTime+0.16);
  }catch(e){}
}

// ── BATTLE ENGINE ───────────────────────────────────────────────────
async function startBattle(){
  if(fighting)return;
  fighting=true;
  const btn=document.getElementById('fBtn');
  btn.disabled=true; btn.textContent='⚔ FIGHTING...';
  document.getElementById('uFlash').classList.remove('show');
  document.getElementById('victoryOverlay').classList.remove('show');
  particles=[];
  const mp=document.getElementById('movePicker');if(mp)mp.innerHTML='';

  // Clear battle log
  const blog=document.getElementById('blog');if(blog)blog.innerHTML='';

  // Reset fighter elements
  ['L','R'].forEach(s=>gm(s==='L'?selL:selR,s).forEach((_,i)=>{
    const f=document.getElementById('fighter-'+s+'-'+i);
    if(f){
      f.classList.remove('dead','attacking','hurt','dying','exploded');
      f.style.cssText='';
    }
  }));

  // Reset HP
  monHP={};
  buildHPBars();
  cL=mxL; cR=mxR;

  const mL=gm(selL,'L'), mR=gm(selR,'R');
  addLog('⚔️',mL.map(m=>m.name).join(' & ')+' VS '+mR.map(m=>m.name).join(' & '),'hl');
  await sleep(400);

  // dead tracks original indices in selL/selR
  const dead={L:new Set(), R:new Set()};
  let upsetOccurred=false;

  // aliveMons returns [{m, origIdx}] where origIdx = index in selL/selR
  function aliveMons(side){
    const sel=side==='L'?selL:selR;
    return gm(sel,side).map((m,origIdx)=>({m,origIdx})).filter(({origIdx})=>!dead[side].has(origIdx));
  }
  function allDead(side){ return aliveMons(side).length===0; }

  outer:
  for(let r=0;r<999;r++){
    if(allDead('L')||allDead('R')) break;
    await sleep(420);

    for(const [atkSide,defSide] of [['L','R'],['R','L']]){
      if(allDead('L')||allDead('R')) break outer;

      const alive_atk=aliveMons(atkSide);
      const alive_def=aliveMons(defSide);
      if(!alive_atk.length||!alive_def.length) continue;

      // Weighted attacker pick by power
      const tot=alive_atk.reduce((s,{m})=>s+m.power,0)||1;
      let pick=Math.random()*tot, ai_pick=0;
      for(let x=0;x<alive_atk.length;x++){
        pick-=alive_atk[x].m.power;
        if(pick<=0){ai_pick=x;break;}
      }
      const {m:atk,origIdx:ai}=alive_atk[ai_pick];
      const {m:def,origIdx:di}=alive_def[Math.floor(Math.random()*alive_def.length)];

      const atkEl=document.getElementById('fighter-'+atkSide+'-'+ai);
      const defEl=document.getElementById('fighter-'+defSide+'-'+di);

      // Charge sound + lunge animation
      sfxCharge();
      if(atkEl){
        atkEl.style.animation='none';
        void atkEl.offsetWidth;
        atkEl.style.animation=(atkSide==='L'?'lunge':'lungel')+' .35s ease-in-out';
      }
      await sleep(160);

      const res=rollAtk(atk.power,def.power);
      const ac2=getFighterCenter(atkSide,ai);
      const dc=getFighterCenter(defSide,di);

      if(!res.hit){
        sfxMiss();
        if(defEl){defEl.style.animation='none';void defEl.offsetWidth;defEl.style.animation='fhurt .25s';}
        showHit(defSide,0,false,true,false);
        addLog('💨',atk.name+' misses '+def.name+'!','miss');
      } else {
        spawnParticles(atk.type,ac2.x,ac2.y,dc.x,dc.y);
        await sleep(100);
        if(res.crit){ sfxCrit(); }
        else if(res.upset){ sfxUpset(); }
        else { sfxHit(atk.power); }
        if(defEl){defEl.style.animation='none';void defEl.offsetWidth;defEl.style.animation='fhurt .3s';}
        showHit(defSide,res.dmg,res.crit,false,res.upset);

        if(res.upset){
          upsetOccurred=true;
          addLog('🔮','UPSET!! '+atk.name+' wrecks '+def.name+' for '+res.dmg+'!','upset');
          document.getElementById('uFlash').classList.add('show');
          setTimeout(()=>document.getElementById('uFlash').classList.remove('show'),2200);
        } else if(res.crit){
          addLog('💥','CRIT! '+atk.name+' smashes '+def.name+' for '+res.dmg+'!','crit');
        } else {
          addLog('⚡',atk.name+' hits '+def.name+' for '+res.dmg,'dmg');
        }

        const defKey=defSide+'_'+di;
        if(monHP[defKey]){
          monHP[defKey].cur=Math.max(0,monHP[defKey].cur-res.dmg);
          setMonHP(defSide,di,monHP[defKey].cur,monHP[defKey].max);
          if(monHP[defKey].cur<=0 && !dead[defSide].has(di)){
            dead[defSide].add(di); // di is origIdx
            sfxKO();
            setMonDead(defSide,di);
            triggerExplosion(defEl||atkEl,defEl||atkEl,def.type);
            addLog('💀',def.name+' is KO\'d!','crit');
          }
        }
      }

      await sleep(220);
      if(atkEl) atkEl.style.animation='';
      if(defEl&&!dead[defSide].has(di)) defEl.style.animation='';
    }
  }

  // Resolve winner
  await sleep(350);
  let wSide,lSide;
  if(allDead('L')&&!allDead('R')){lSide='L';wSide='R';}
  else if(allDead('R')&&!allDead('L')){lSide='R';wSide='L';}
  else{
    const hpL=aliveMons('L').reduce((s,{origIdx})=>s+(monHP['L_'+origIdx]?.cur||0),0);
    const hpR=aliveMons('R').reduce((s,{origIdx})=>s+(monHP['R_'+origIdx]?.cur||0),0);
    wSide=hpL>=hpR?'L':'R'; lSide=wSide==='L'?'R':'L';
  }

  // KO remaining losers
  aliveMons(lSide).forEach(({m,origIdx})=>{
    setMonDead(lSide,origIdx);
    const f=document.getElementById('fighter-'+lSide+'-'+origIdx);
    if(f&&!f.classList.contains('exploded')) triggerExplosion(f,f,m.type);
  });

  const wMs=gm(wSide==='L'?selL:selR,wSide);
  const lMs=gm(lSide==='L'?selL:selR,lSide);
  const wn=wMs.map(m=>m.name).join(' & ');
  const ln=lMs.map(m=>m.name).join(' & ');
  addLog('🏆',wn+' WIN!','win');

  S.battleHistory.unshift({w:wn,l:ln,wSide,date:new Date().toLocaleDateString(),upset:upsetOccurred});
  if(S.battleHistory.length>20)S.battleHistory.pop();

  document.getElementById('vName').textContent=wn;
  document.getElementById('vSub').textContent=(wSide==='L'?'Team 1':'Team 2')+' defeated '+ln+'!'+(upsetOccurred?' 🔮':'');
  document.getElementById('vUpset').classList.toggle('show',upsetOccurred);
  document.getElementById('vTrophy').textContent=upsetOccurred?'😱':'🏆';

  await sleep(500);
  sfxVictory();
  spawnConfetti();
  document.getElementById('victoryOverlay').classList.add('show');
  await sleep(400);
  fighting=false;
  btn.disabled=false;
  btn.textContent='⚔ FIGHT AGAIN!';
}

// ── COLOR HELPERS & EXPLOSION ──────────────────────────────────────
const EXPL_EMOJI = ['💀','⭐','✨','💫','🌟','😵','👻','🔥','⚡','💥','🤯'];
const TYPE_COLORS = {
  fire:    ['#FF6D00','#FF9800','#FFD600','#FF3D00','#fff'],
  water:   ['#29B6F6','#4FC3F7','#B3E5FC','#0277BD','#fff'],
  thunder: ['#FFD600','#FFEA00','#FF6D00','#FFF176','#fff'],
  shadow:  ['#9C27B0','#E040FB','#CE93D8','#4A148C','#fff'],
  wind:    ['#80DEEA','#4DD0E1','#B2EBF2','#00838F','#fff'],
  blob:    ['#F06292','#E91E63','#FF80AB','#FCE4EC','#fff'],
  knight:  ['#90A4AE','#78909C','#FFD600','#37474F','#fff'],
  cube:    ['#AB47BC','#CE93D8','#6A1B9A','#E040FB','#fff'],
};
function getColors(type){ return TYPE_COLORS[type]||TYPE_COLORS.blob; }

function mk(tag, cls){
  const el = document.createElement(tag);
  if(cls) el.className = cls;
  return el;
}

function triggerExplosion(wrapEl, monEl, type){
  if(!monEl || monEl.classList.contains('dying') || monEl.classList.contains('exploded')) return;
  const colors = getColors(type);
  const mainColor = colors[0];

  // Screen shake
  document.body.classList.remove('shaking');
  void document.body.offsetWidth;
  document.body.classList.add('shaking');
  setTimeout(()=>document.body.classList.remove('shaking'), 400);

  monEl.classList.add('dying');
  setTimeout(()=>{
    monEl.classList.add('exploded');

    const parent = wrapEl || monEl;
    parent.appendChild(mk('div','expl-flash'));
    parent.appendChild(mk('div','expl-fireball'));
    for(let i=1;i<=3;i++) parent.appendChild(mk('div',`expl-sw s${i}`));

    const ko=mk('div','expl-ko'); ko.textContent='KO!'; parent.appendChild(ko);
    const ghost=mk('div','expl-ghost'); ghost.textContent='👻'; parent.appendChild(ghost);
    const crater=mk('div','expl-crater');
    crater.style.background=`radial-gradient(ellipse,${mainColor}99 0%,transparent 70%)`;
    parent.appendChild(crater);

    for(let i=0;i<24;i++){
      const d=mk('div','expl-debris'+(Math.random()>.5?' sq':''));
      const angle=(i/24)*Math.PI*2+(Math.random()-.5)*.5;
      const dist=50+Math.random()*80;
      const c=colors[Math.floor(Math.random()*colors.length)];
      const size=5+Math.random()*12;
      const dur=.4+Math.random()*.3;
      d.style.cssText=`width:${size}px;height:${size}px;background:${c};--dx:${Math.cos(angle)*dist}px;--dy:${Math.sin(angle)*dist-25}px;--rot:${(Math.random()-.5)*720}deg;animation:debris-fly ${dur}s cubic-bezier(0.1,0.6,0.3,1) forwards;`;
      parent.appendChild(d);
    }

    for(let i=0;i<8;i++){
      const s=mk('div','expl-emoji');
      const angle=(i/8)*Math.PI*2+(Math.random()-.5)*.4;
      const dist=55+Math.random()*50;
      s.textContent=EXPL_EMOJI[Math.floor(Math.random()*EXPL_EMOJI.length)];
      s.style.cssText=`font-size:${14+Math.random()*14}px;--dx:${Math.cos(angle)*dist}px;--dy:${Math.sin(angle)*dist-30}px;--rot:${(Math.random()-.5)*720}deg;--dur:${.5+Math.random()*.3}s;`;
      parent.appendChild(s);
    }

    setTimeout(()=>{
      parent.querySelectorAll('.expl-flash,.expl-fireball,.expl-sw,.expl-debris,.expl-emoji,.expl-smoke,.expl-ghost,.expl-ko,.expl-crater').forEach(e=>e.remove());
      monEl.style.transition='opacity .4s ease-out';
      monEl.style.opacity='0';
    }, 1400);
    setTimeout(()=>{ monEl.style.display='none'; }, 1800);
  }, 80);
}

// Init — all deferred until DOM is ready
window.addEventListener('resize', resizeParticleCanvas);
window.addEventListener('pagehide', saveGame);
window.addEventListener('beforeunload', saveGame);


// ── SOUND EFFECTS ──────────────────────────────────────────────────

function ac(){if(!_ac)_ac=new(window.AudioContext||window.webkitAudioContext)();return _ac;}
function beep(freq,dur,vol,type,delay){
  try{
    const a=ac(),o=a.createOscillator(),g=a.createGain();
    o.connect(g);g.connect(a.destination);
    o.type=type||'sine';o.frequency.setValueAtTime(freq,a.currentTime+(delay||0));
    g.gain.setValueAtTime(vol||0.15,a.currentTime+(delay||0));
    g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+(delay||0)+dur);
    o.start(a.currentTime+(delay||0));o.stop(a.currentTime+(delay||0)+dur+0.05);
  }catch(e){}
}
function sfx(type){
  try{
    if(type==='award'){beep(523,.07,.18,'square');beep(659,.07,.18,'square',.08);beep(784,.12,.2,'square',.16);}
    else if(type==='levelup'){[523,659,784,1047].forEach((f,i)=>beep(f,.1,.2,'square',i*.1));}
    else if(type==='buy'){beep(440,.08,.15,'sine');beep(550,.1,.15,'sine',.09);}
    else if(type==='hit'){beep(180,.06,.25,'sawtooth');beep(120,.08,.2,'sawtooth',.05);}
    else if(type==='crit'){beep(300,.04,.3,'square');beep(600,.06,.25,'square',.05);beep(900,.08,.2,'square',.1);}
    else if(type==='win'){[523,659,784,659,784,1047].forEach((f,i)=>beep(f,.1,.18,'square',i*.1));}
    else if(type==='fuse'){beep(200,.1,.2,'sawtooth');beep(400,.1,.2,'sine',.1);beep(800,.2,.25,'square',.2);}
    else if(type==='streak'){beep(440,.06,.15,'sine');beep(554,.06,.15,'sine',.07);beep(659,.1,.2,'sine',.14);}
    else if(type==='dq-hit'){beep(150+Math.random()*80,.08,.2,'sawtooth');beep(80,.1,.15,'sawtooth',.07);}
    else if(type==='dq-ko'){beep(120,.06,.3,'sawtooth');beep(80,.12,.25,'sawtooth',.08);beep(50,.2,.2,'sine',.18);}
    else if(type==='dq-heal'){beep(523,.08,.12,'sine');beep(659,.08,.12,'sine',.09);beep(784,.12,.15,'sine',.18);}
    else if(type==='dq-floor'){beep(220,.1,.15,'square');beep(330,.1,.15,'square',.1);beep(440,.15,.18,'square',.2);}
    else if(type==='dq-win'){[523,659,784,1047,784,880,1047,1175].forEach((f,i)=>beep(f,.1,.18,'square',i*.12));}
    else if(type==='dq-loss'){[300,250,200,150,100].forEach((f,i)=>beep(f,.15,.2,'sawtooth',i*.15));}
    else if(type==='dq-boss'){beep(80,.2,.3,'sawtooth');beep(60,.3,.25,'sawtooth',.18);beep(100,.15,.2,'square',.35);}
    else if(type==='dq-enter'){[440,554,659,554,440].forEach((f,i)=>beep(f,.08,.15,'square',i*.1));}
  }catch(e){}
}

function showLevelUp(kidIdx,lv,freePulled){
  const k=S.kids[kidIdx];
  const el=document.createElement('div');
  el.id='lvlUpOverlay';el.style.cssText='position:fixed;inset:0;z-index:9500;background:rgba(0,0,0,0.88);display:flex;align-items:center;justify-content:center';
  const card=document.createElement('div');
  card.style.cssText='background:linear-gradient(145deg,#1a0030,#2d1060);border:3px solid #FFD600;border-radius:24px;padding:28px 36px;text-align:center;max-width:320px;animation:winpop .5s cubic-bezier(.34,1.56,.64,1)';
  const cardNames=freePulled.map(m=>'<span style="display:inline-block;background:rgba(255,214,0,0.1);border:1px solid #FFD600;border-radius:8px;padding:2px 8px;margin:2px;font-size:10px;color:#FFD600">'+m.name+'</span>').join('');
  card.innerHTML='<div style="font-size:48px;margin-bottom:8px">⬆️</div>'
    +'<div style="font-size:22px;font-weight:900;color:#FFD600;letter-spacing:2px;margin-bottom:4px">LEVEL UP!</div>'
    +'<div style="font-size:16px;font-weight:700;color:white;margin-bottom:4px">'+k.name+' is now Level '+lv+'!</div>'
    +'<div style="font-size:11px;color:#c4982a;margin-bottom:12px">Free pack reward:</div>'
    +'<div style="margin-bottom:16px">'+cardNames+'</div>'
    +'<button onclick="document.getElementById(\'lvlUpOverlay\').remove();rKids();" style="padding:10px 28px;background:linear-gradient(135deg,#FFD600,#FF8C00);border:none;border-radius:12px;font-size:14px;font-weight:900;color:#120a04;cursor:pointer">Awesome! 🎉</button>';
  el.appendChild(card);
  el.addEventListener('click',e=>{if(e.target===el){el.remove();rKids();}});
  document.body.appendChild(el);
  spawnConfetti();
}
function spawnConfetti(){
  const colors=['#FF6B6B','#FFD600','#4ECDC4','#A855F7','#6BCB77','#FF8E53'];
  for(let i=0;i<60;i++){
    const d=document.createElement('div');
    const color=colors[Math.floor(Math.random()*colors.length)];
    const size=6+Math.random()*8;
    d.style.cssText='position:fixed;width:'+size+'px;height:'+size+'px;background:'+color
      +';left:'+Math.random()*100+'vw;top:-10px;border-radius:'+(Math.random()>0.5?'50%':'2px')
      +';z-index:9999;pointer-events:none;animation:confettiFall '+(1.5+Math.random()*2)+'s ease-in forwards '+(Math.random()*0.8)+'s';
    document.body.appendChild(d);
    setTimeout(()=>d.remove(),4000);
  }
}

function checkCollectionComplete(kidIdx){
  const k=S.kids[kidIdx];
  const arenaIds=new Set(MONSTERS.map(m=>m.id));
  const owned=new Set(k.col.filter(m=>arenaIds.has(m.id)).map(m=>m.id));
  if(owned.size>=MONSTERS.length && !k.collectionComplete){
    k.collectionComplete=true;
    sfx('win');
    const el=document.createElement('div');
    el.style.cssText='position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.9);display:flex;align-items:center;justify-content:center';
    el.id='collCompleteOverlay';el.innerHTML='<div style="background:linear-gradient(145deg,#0a1a04,#1a3010);border:3px solid #76FF03;border-radius:24px;padding:32px 40px;text-align:center;max-width:340px;animation:winpop .5s ease">'
      +'<div style="font-size:52px;margin-bottom:8px">🏆</div>'
      +'<div style="font-size:20px;font-weight:900;color:#76FF03;letter-spacing:2px;margin-bottom:8px">COLLECTION COMPLETE!</div>'
      +'<div style="font-size:14px;color:white;margin-bottom:6px">'+k.name+' caught all '+MONSTERS.length+' monsters!</div>'
      +'<div style="font-size:11px;color:#a5d6a7;margin-bottom:16px">A Master Trainer trophy has been added to your card!</div>'
      +'<button onclick="document.getElementById(\'collCompleteOverlay\').remove();rKids();" style="padding:11px 28px;background:linear-gradient(135deg,#76FF03,#4CAF50);border:none;border-radius:12px;font-size:14px;font-weight:900;color:#0a1a04;cursor:pointer">👑 Claim Trophy!</button>'
      +'</div>';
    el.addEventListener('click',e=>{if(e.target===el){el.remove();rKids();}});
    document.body.appendChild(el);
    spawnConfetti();
  }
}

function handleMonClick(el){
  const uid=parseFloat(el.dataset.uid);
  const nick=el.dataset.nick||'';
  nickMonster(uid,nick);
}
function nickMonster(uid,currentName){
  const existing=document.getElementById('nickModal');
  if(existing)existing.remove();
  const overlay=document.createElement('div');
  overlay.id='nickModal';
  overlay.style.cssText='position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);display:flex;align-items:center;justify-content:center';
  const box=document.createElement('div');
  box.style.cssText='background:#1a1008;border:2px solid #FFD600;border-radius:14px;padding:24px;min-width:260px;text-align:center;box-shadow:0 0 40px rgba(255,214,0,0.3)';
  box.innerHTML='<div style="font-size:13px;font-weight:900;color:#FFD600;margin-bottom:12px;text-transform:uppercase;letter-spacing:2px">🏷️ Nickname Monster</div>'
    +'<input id="nickInput" value="" style="width:100%;padding:10px;border-radius:8px;border:2px solid #FFD600;background:#120a04;color:#FFD600;font-size:15px;font-weight:700;text-align:center;outline:none;box-sizing:border-box" maxlength="18">'
    +'<div style="display:flex;gap:8px;margin-top:12px">'
    +'<button id="nickCancelBtn" style="flex:1;padding:9px;border-radius:8px;border:1px solid rgba(255,214,0,0.3);background:transparent;color:#c4982a;font-weight:700;cursor:pointer">Cancel</button>'
    +'<button id="nickSaveBtn" style="flex:1;padding:9px;border-radius:8px;border:none;background:linear-gradient(135deg,#FFD600,#FF8C00);color:#120a04;font-weight:900;cursor:pointer">Save ✓</button>'
    +'</div>';
  overlay.appendChild(box);
  document.body.appendChild(overlay);
  const inp=document.getElementById('nickInput');
  inp.value=currentName;
  setTimeout(()=>{inp.focus();inp.select();},50);
  overlay.addEventListener('click',e=>{if(e.target===overlay)overlay.remove();});
  document.getElementById('nickCancelBtn').onclick=()=>overlay.remove();
  document.getElementById('nickSaveBtn').onclick=()=>saveNick(uid);
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')saveNick(uid);});
}

function saveNick(uid){
  const inp=document.getElementById('nickInput');
  if(!inp)return;
  const val=inp.value.trim();
  if(!val)return;
  // Store nick on the kid who owns this monster uid
  S.kids.forEach(k=>{
    const mon=k.col.find(m=>m.uid===uid);
    if(mon){k.nicks=k.nicks||{};k.nicks[uid]=val;}
  });
  document.getElementById('nickModal').remove();
  rCol();
}
function getMonName(kidIdx,mon){
  const nicks=S.kids[kidIdx]?.nicks||{};
  return nicks[mon.uid]||mon.name;
}

function renderBattleHistory(){
  const box=document.getElementById('battleHistoryList');
  if(!box)return;
  if(!S.battleHistory.length){box.innerHTML='<div class="es">No battles yet! ⚔️<br><small>Pick monsters and hit FIGHT!</small></div>';return;}
  box.innerHTML=S.battleHistory.slice(0,8).map(b=>{
    const icon=b.upset?'🔮':'🏆';
    const wColor=b.upset?'#9C27B0':'#2e7d32';
    return '<div class="bh-row">'
      +'<span class="bh-winner" style="color:'+wColor+'">'+icon+' '+b.w+'</span>'
      +'<span class="bh-vs">vs</span>'
      +'<span class="bh-loser">'+b.l+'</span>'
      +'<span class="bh-date">'+b.date+'</span>'
      +'</div>';
  }).join('');
}

var fusionSel=[];
function openFusion(){
  const k=S.kids[S.ck];
  // Find monsters with duplicates
  const counts={};
  k.col.forEach(m=>{counts[m.id]=(counts[m.id]||0)+1;});
  const dupes=k.col.filter((m,i,a)=>counts[m.id]>=2&&a.findIndex(x=>x.id===m.id)===i);
  if(dupes.length<2){toast('Need 2 duplicate monsters to fuse! 🔮');return;}
  fusionSel=[];
  const el=document.createElement('div');
  el.id='fusionModal';
  el.style.cssText='position:fixed;inset:0;z-index:9400;background:rgba(0,0,0,0.92);display:flex;align-items:center;justify-content:center;overflow-y:auto';
  const cards=dupes.map(m=>`<div onclick="toggleFusionSel('${m.id}',this)" style="width:80px;border:2px solid #333;border-radius:12px;padding:6px;text-align:center;cursor:pointer;transition:all .15s;background:#1a0a2e" id="fsc-${m.id}">${resizeSvg(m.svg||(MONSTERS.find(a=>a.id===m.id)||{}).svg||'',52,52)}<div style="font-size:8px;color:#FFD600;font-weight:700">${m.name}</div><div style="font-size:8px;color:#FF8C00">⚡${m.power} ×${counts[m.id]}</div></div>`).join('');
  el.innerHTML='<div style="background:linear-gradient(145deg,#1a0030,#2d1060);border:3px solid #CE93D8;border-radius:24px;padding:24px;max-width:360px;width:92%;text-align:center">'
    +'<div style="font-size:16px;font-weight:900;color:#CE93D8;margin-bottom:4px;letter-spacing:2px">🔮 MONSTER FUSION</div>'
    +'<div style="font-size:10px;color:#b0a0cc;margin-bottom:14px">Pick 2 duplicates → fuse into a stronger monster!</div>'
    +'<div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:14px">'+cards+'</div>'
    +'<button id="fuseBtn" disabled onclick="doFusion()" style="width:100%;padding:11px;background:linear-gradient(135deg,#7B1FA2,#E91E63);border:none;border-radius:12px;font-size:13px;font-weight:900;color:white;cursor:pointer;opacity:.5">Select 2 Monsters</button>'
    +'<button onclick="document.getElementById(\'fusionModal\').remove()" style="width:100%;margin-top:8px;padding:9px;background:transparent;border:1px solid rgba(255,255,255,0.2);border-radius:12px;color:#b0a0cc;cursor:pointer;font-size:12px">Cancel</button>'
    +'</div>';
  document.body.appendChild(el);
}
function toggleFusionSel(id,el){
  const idx=fusionSel.indexOf(id);
  if(idx>=0){fusionSel.splice(idx,1);el.style.border='2px solid #333';el.style.background='#1a0a2e';}
  else if(fusionSel.length<2){fusionSel.push(id);el.style.border='2px solid #CE93D8';el.style.background='rgba(206,147,216,0.15)';}
  const btn=document.getElementById('fuseBtn');
  if(btn){btn.disabled=fusionSel.length!==2;btn.style.opacity=fusionSel.length===2?'1':'0.5';btn.textContent=fusionSel.length===2?'⚡ FUSE!':'Select 2 Monsters';}
}
function doFusion(){
  if(fusionSel.length!==2)return;
  const k=S.kids[S.ck];
  const m1=MONSTERS.find(m=>m.id===fusionSel[0]);
  const m2=MONSTERS.find(m=>m.id===fusionSel[1]);
  if(!m1||!m2)return;
  // Remove one copy of each from collection
  [fusionSel[0],fusionSel[1]].forEach(id=>{
    const idx=k.col.findIndex(m=>m.id===id);
    if(idx>=0)k.col.splice(idx,1);
  });
  // Create fused monster - higher power, new name
  const fusedPower=Math.min(10,Math.round((m1.power+m2.power)*0.7+1));
  const fusedMon={...m1,name:'⚡'+m1.name.split(' ')[0]+'-'+m2.name.split(' ')[0],power:fusedPower,rarity:fusedPower>=9?'legendary':fusedPower>=7?'epic':fusedPower>=5?'rare':'common',uid:Date.now()+Math.random()};
  k.col.push(fusedMon);
  document.getElementById('fusionModal').remove();
  sfx('fuse');
  toast('🔮 Fusion! '+fusedMon.name+' ⚡'+fusedMon.power+' created!');
  rKids();rCol();
}


// ── TREASURE CHESTS ────────────────────────────────────────────────
function openTreasureChests(){
  const btn=document.getElementById('dqChestBtn');
  if(btn)btn.style.display='none';
  const area=document.getElementById('dqChestArea');
  if(!area)return;

  // Roll rewards for each kid
  const rewards=S.kids.map((k,ki)=>rollChestReward(ki));
  if(!dqState)return;
  dqState.chestRewards=rewards;

  // Build chest UI - one per kid
  const row=document.createElement('div');
  row.className='dq-chest-row';
  S.kids.forEach((k,ki)=>{
    const chest=document.createElement('div');
    chest.className='dq-chest';
    chest.id='dqChest'+ki;
    chest.innerHTML='<div class="dq-chest-box">🎁</div><div class="dq-chest-label">'+k.name+'</div><div class="dq-chest-reveal" id="dqChestReveal'+ki+'" style="opacity:0"></div>';
    chest.onclick=()=>revealChest(ki);
    row.appendChild(chest);
  });
  area.appendChild(row);

  // Add collect-all button
  const collectBtn=document.createElement('button');
  collectBtn.id='dqCollectBtn';
  collectBtn.className='dq-result-btn';
  collectBtn.style.cssText='margin-top:8px;opacity:0.5;font-size:12px;';
  collectBtn.textContent='Open All & Claim';
  collectBtn.onclick=()=>collectAllChests();
  area.appendChild(collectBtn);
  sfx('dq-floor');
}

function rollChestReward(kidIdx){
  const dlevel=S.dungeonLevel||1;
  const roll=Math.random();
  // Higher dungeon levels = better rewards
  const monsterChance = 0.3 + dlevel * 0.08; // up to ~70% at level 5
  if(roll < monsterChance){
    // Monster reward - higher tier at higher levels
    const minPow = Math.min(6, 1 + Math.floor(dlevel * 0.6));
    const pool = MONSTERS.filter(m=>m.power>=minPow);
    const src = pool.length ? pool : MONSTERS;
    const mon = src[Math.floor(Math.random()*src.length)];
    return {type:'monster', mon, pts:0};
  } else {
    // Points reward - scales with level
    const base = 20 + dlevel * 15;
    const pts = base + Math.floor(Math.random()*base);
    return {type:'pts', pts};
  }
}

let chestsOpened=0;
function revealChest(ki){
  const chest=document.getElementById('dqChest'+ki);
  if(!chest||chest.classList.contains('opened'))return;
  chest.classList.add('opened');
  chest.onclick=null;
  chest.style.cursor='default';
  sfx('buy');
  spawnConfetti();

  if(!dqState||!dqState.chestRewards)return;
  const reward=dqState.chestRewards[ki];
  const revealEl=document.getElementById('dqChestReveal'+ki);
  if(!revealEl)return;

  setTimeout(()=>{
    revealEl.style.animation='chest-reward-pop .4s ease-out forwards';
    revealEl.style.opacity='1';
    if(reward.type==='monster'){
      const svg=resizeSvg(reward.mon.svg||'',36,36);
      revealEl.innerHTML=svg+'<div style="color:#FFD600;font-size:10px;font-weight:800">'+reward.mon.name+'</div><div style="color:#FF8C00;font-size:9px">⚡'+reward.mon.power+'</div>';
    } else {
      revealEl.innerHTML='<div style="font-size:22px">💰</div><div style="color:#FFD600;font-size:13px;font-weight:900">+'+reward.pts+'</div><div style="color:#c4982a;font-size:9px">pts</div>';
    }
    chestsOpened++;
    // If all chests opened, activate the collect button
    if(chestsOpened>=S.kids.length){
      const cb=document.getElementById('dqCollectBtn');
      if(cb){cb.style.opacity='1';cb.textContent='✓ Collect All Rewards!';}
    }
  },300);
}

function collectAllChests(){
  if(!dqState)return;
  // Capture rewards and base pts NOW before anything clears dqState
  const savedRewards = dqState.chestRewards ? [...dqState.chestRewards] : [];
  const savedBasePts = dqState.reward || 0;
  // Open any unopened chests visually first
  S.kids.forEach((_,ki)=>revealChest(ki));
  setTimeout(()=>{
    // Apply all rewards
    savedRewards.forEach((r,ki)=>{
      if(r.type==='monster'){
        S.kids[ki].col.push({...r.mon, uid:Date.now()+Math.random()+ki});
        toast(S.kids[ki].name+' got '+r.mon.name+'! 🎉');
      } else {
        S.kids[ki].pts+=r.pts;
        toast(S.kids[ki].name+' got +'+r.pts+' pts! 💰');
      }
    });
    // Give base dungeon pts
    if(savedBasePts){
      const each=Math.floor(savedBasePts/3);
      S.kids.forEach(k=>k.pts+=each);
    }
    rKids();saveGame();
    closeDQFinal();
  },600);
}

function closeDQFinal(){
  chestsOpened=0;
  document.getElementById('dqOverlay').classList.remove('show');
  dqState=null;
}

